<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:views="clr-namespace:NexusApp.Views"
                    xmlns:conv="clr-namespace:NexusApp.Converters">

    <!-- Base palette tokens live in Themes/Palette.Luxury.xaml / Palette.Classic.xaml,
         merged ahead of this dictionary and swapped at runtime by ThemeService.
         The brushes below bind their Color via DynamicResource so a palette swap
         repaints the whole app live. -->

    <!-- Shared motion vocabulary (mirrors Views/Motion.cs): the named easing curves
         the MOBIGLAS mocks are authored with. Entrances settle, page reveals use the
         reveal bezier, ambient loops breathe, UI slides decelerate. -->
    <views:CubicBezierEase x:Key="EaseSettle" X1="0.16" Y1="0.8" X2="0.3" Y2="1"/>
    <views:CubicBezierEase x:Key="EaseReveal" X1="0.2" Y1="0.8" X2="0.2" Y2="1"/>
    <SineEase x:Key="EaseBreathe" EasingMode="EaseInOut"/>
    <CubicEase x:Key="EaseSlideOut" EasingMode="EaseOut"/>

    <!-- Tier colors -->
    <Color x:Key="TierSColor">#FFFFD700</Color>
    <Color x:Key="TierAColor">#FF4CAF50</Color>
    <Color x:Key="TierBColor">#FF29B6F6</Color>
    <Color x:Key="TierCColor">#FFFFFFFF</Color>

    <!-- Rarity colors -->
    <Color x:Key="RarityLegendaryColor">#FFFFD700</Color>
    <Color x:Key="RarityEpicColor">#FFA855F7</Color>
    <Color x:Key="RarityRareColor">#FF3B82F6</Color>
    <Color x:Key="RarityUncommonColor">#FF22C55E</Color>
    <Color x:Key="RarityCommonColor">#FF9E9E9E</Color>

    <!-- System colors -->
    <Color x:Key="SystemStantonColor">#FF3B82F6</Color>
    <Color x:Key="SystemPyroColor">#FFF97316</Color>
    <Color x:Key="SystemNyxColor">#FFA78BFA</Color>

    <!-- Brushes - Color via DynamicResource so a palette swap repaints live -->
    <SolidColorBrush x:Key="BgBrush"       Color="{DynamicResource BgColor}"/>
    <SolidColorBrush x:Key="Bg2Brush"      Color="{DynamicResource Bg2Color}"/>
    <SolidColorBrush x:Key="Bg3Brush"      Color="{DynamicResource Bg3Color}"/>
    <SolidColorBrush x:Key="BorderBrush"   Color="{DynamicResource BorderColor}"/>
    <SolidColorBrush x:Key="NavBorderBrush" Color="{DynamicResource NavBorderColor}"/>
    <SolidColorBrush x:Key="FgBrush"       Color="{DynamicResource FgColor}"/>
    <SolidColorBrush x:Key="FgDimBrush"    Color="{DynamicResource FgDimColor}"/>
    <SolidColorBrush x:Key="AccentBrush"   Color="{DynamicResource AccentColor}"/>
    <SolidColorBrush x:Key="AccentDimBrush" Color="{DynamicResource AccentDimColor}"/>
    <SolidColorBrush x:Key="GoldBrush"     Color="{DynamicResource GoldColor}"/>
    <SolidColorBrush x:Key="NavBgBrush"    Color="{DynamicResource NavBgColor}"/>
    <SolidColorBrush x:Key="PageBgBrush"   Color="{DynamicResource PageBgColor}"/>
    <SolidColorBrush x:Key="Bg2NavBrush"   Color="{DynamicResource Bg2NavColor}"/>
    <SolidColorBrush x:Key="HighlightBrush" Color="{DynamicResource HighlightColor}"/>

    <!-- accent-derived + role brushes (also palette-swapped) -->
    <SolidColorBrush x:Key="AccentClearBrush"  Color="{DynamicResource AccentClearColor}"/>
    <SolidColorBrush x:Key="AccentFaintBrush"  Color="{DynamicResource AccentFaintColor}"/>
    <SolidColorBrush x:Key="AccentTintBrush"   Color="{DynamicResource AccentTintColor}"/>
    <SolidColorBrush x:Key="AccentSoftBrush"   Color="{DynamicResource AccentSoftColor}"/>
    <SolidColorBrush x:Key="AccentGlowBrush"   Color="{DynamicResource AccentGlowColor}"/>
    <SolidColorBrush x:Key="AccentStrongBrush" Color="{DynamicResource AccentStrongColor}"/>
    <SolidColorBrush x:Key="AccentHoverBrush"  Color="{DynamicResource AccentHoverColor}"/>
    <SolidColorBrush x:Key="AccentPressBrush"  Color="{DynamicResource AccentPressColor}"/>
    <SolidColorBrush x:Key="OnAccentBrush"     Color="{DynamicResource OnAccentColor}"/>
    <SolidColorBrush x:Key="OverlayBgTopBrush" Color="{DynamicResource OverlayBgTopColor}"/>
    <SolidColorBrush x:Key="OverlayBgBotBrush" Color="{DynamicResource OverlayBgBotColor}"/>

    <!-- ice-cyan secondary (live readouts / lock-on) + semantic status brushes -->
    <SolidColorBrush x:Key="CyanBrush"     Color="{DynamicResource CyanColor}"/>
    <SolidColorBrush x:Key="CyanDimBrush"  Color="{DynamicResource CyanDimColor}"/>
    <SolidColorBrush x:Key="CyanLineBrush" Color="{DynamicResource CyanLineColor}"/>
    <SolidColorBrush x:Key="CyanGlowBrush" Color="{DynamicResource CyanGlowColor}"/>
    <SolidColorBrush x:Key="DangerBrush"   Color="{DynamicResource DangerColor}"/>
    <SolidColorBrush x:Key="OkBrush"       Color="{DynamicResource OkColor}"/>
    <SolidColorBrush x:Key="WarnBrush"     Color="{DynamicResource WarnColor}"/>

    <!-- Typography (MOBIGLAS): Chakra Petch UI/labels, Rajdhani display, JetBrains Mono data.
         Pack-URI-only to match the proven Outfit pattern; WPF auto-falls back if a face is missing.
         TechFont is an explicit alias for Chakra Petch where a HUD label is wanted. -->
    <FontFamily x:Key="UiFont">/NexusApp;component/Assets/Fonts/#Chakra Petch</FontFamily>
    <FontFamily x:Key="HeadFont">/NexusApp;component/Assets/Fonts/#Chakra Petch</FontFamily>
    <FontFamily x:Key="TechFont">/NexusApp;component/Assets/Fonts/#Chakra Petch</FontFamily>
    <FontFamily x:Key="DisplayFont">/NexusApp;component/Assets/Fonts/#Rajdhani</FontFamily>
    <FontFamily x:Key="MonoFont">/NexusApp;component/Assets/Fonts/#JetBrains Mono</FontFamily>
    <System:Double xmlns:System="clr-namespace:System;assembly=mscorlib" x:Key="FontSm">11</System:Double>
    <System:Double xmlns:System="clr-namespace:System;assembly=mscorlib" x:Key="FontMd">13</System:Double>
    <System:Double xmlns:System="clr-namespace:System;assembly=mscorlib" x:Key="FontLg">15</System:Double>
    <System:Double xmlns:System="clr-namespace:System;assembly=mscorlib" x:Key="FontXl">20</System:Double>

    <!-- ── NexusButton: secondary/clear button - Bg3 bg, dim text, subtle border -->
    <Style x:Key="NexusButton" TargetType="Button">
        <Setter Property="Background"      Value="{DynamicResource Bg3Brush}"/>
        <Setter Property="Foreground"      Value="{DynamicResource FgDimBrush}"/>
        <Setter Property="BorderBrush"     Value="{DynamicResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding"         Value="12,6"/>
        <Setter Property="FontFamily"      Value="{StaticResource UiFont}"/>
        <Setter Property="FontSize"        Value="{StaticResource FontMd}"/>
        <Setter Property="Cursor"          Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="4"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="{DynamicResource BorderBrush}"/>
                            <Setter Property="Foreground" Value="{DynamicResource FgBrush}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="border" Property="Opacity" Value="0.75"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── AccentButton: primary action - teal bg, dark text -->
    <Style x:Key="AccentButton" TargetType="Button" BasedOn="{StaticResource NexusButton}">
        <Setter Property="Background"  Value="{DynamicResource AccentBrush}"/>
        <Setter Property="Foreground"  Value="{DynamicResource OnAccentBrush}"/>
        <Setter Property="FontWeight"  Value="Bold"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            CornerRadius="4"
                            Padding="{TemplateBinding Padding}">
                        <Border.Effect>
                            <DropShadowEffect Color="{DynamicResource AccentColor}" BlurRadius="16" ShadowDepth="0" Opacity="0.40"/>
                        </Border.Effect>
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="{DynamicResource AccentHoverBrush}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="border" Property="Background" Value="{DynamicResource AccentPressBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── HeaderButton: transparent bg, dim text, thin border (window controls + overlay btn) -->
    <Style x:Key="HeaderButton" TargetType="Button">
        <Setter Property="Background"      Value="Transparent"/>
        <Setter Property="Foreground"      Value="{DynamicResource FgDimBrush}"/>
        <Setter Property="BorderBrush"     Value="{DynamicResource NavBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding"         Value="0"/>
        <Setter Property="FontFamily"      Value="{StaticResource UiFont}"/>
        <Setter Property="FontSize"        Value="15"/>
        <Setter Property="Cursor"          Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="4"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Foreground" Value="{DynamicResource FgBrush}"/>
                            <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource NavBorderBrush}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                            <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                            <Setter TargetName="border" Property="Background" Value="{DynamicResource AccentFaintBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── NavButton: sidebar nav items - RadioButton with left accent bar -->
    <Style x:Key="NavButton" TargetType="RadioButton">
        <Setter Property="Background"               Value="Transparent"/>
        <Setter Property="Foreground"               Value="{DynamicResource FgDimBrush}"/>
        <Setter Property="Padding"                  Value="10,9"/>
        <Setter Property="FontFamily"               Value="{StaticResource UiFont}"/>
        <Setter Property="FontSize"                 Value="12.5"/>
        <Setter Property="FontWeight"               Value="SemiBold"/>
        <Setter Property="Cursor"                   Value="Hand"/>
        <Setter Property="HorizontalContentAlignment" Value="Left"/>
        <Setter Property="MinHeight"                Value="38"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RadioButton">
                    <Border x:Name="outer" Background="{TemplateBinding Background}"
                            CornerRadius="4" Margin="7,1" BorderBrush="Transparent" BorderThickness="1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="3"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border x:Name="accentBar" Grid.Column="0" Background="Transparent" CornerRadius="2"/>
                            <ContentPresenter Grid.Column="1"
                                              Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="Stretch"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True"/>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="outer" Property="Background" Value="{DynamicResource HighlightBrush}"/>
                            <Setter Property="Foreground" Value="{DynamicResource FgBrush}"/>
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="accentBar" Property="Background" Value="{DynamicResource AccentBrush}"/>
                            <Setter TargetName="accentBar" Property="Effect">
                                <Setter.Value>
                                    <DropShadowEffect Color="{DynamicResource AccentColor}" BlurRadius="12" ShadowDepth="0" Opacity="0.55"/>
                                </Setter.Value>
                            </Setter>
                            <Setter TargetName="outer" Property="Background" Value="{DynamicResource AccentFaintBrush}"/>
                            <Setter TargetName="outer" Property="BorderBrush" Value="{DynamicResource AccentStrongBrush}"/>
                            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── TextBox style -->
    <Style x:Key="NexusTextBox" TargetType="TextBox">
        <Setter Property="Background"      Value="{DynamicResource Bg2NavBrush}"/>
        <Setter Property="Foreground"      Value="{DynamicResource FgBrush}"/>
        <Setter Property="BorderBrush"     Value="{DynamicResource NavBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding"         Value="10,8"/>
        <Setter Property="FontFamily"      Value="{StaticResource UiFont}"/>
        <Setter Property="FontSize"        Value="{StaticResource FontMd}"/>
        <Setter Property="CaretBrush"      Value="{DynamicResource AccentBrush}"/>
        <Setter Property="SelectionBrush"  Value="{DynamicResource AccentDimBrush}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="4">
                        <Grid>
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Padding="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"/>
                            <TextBlock x:Name="placeholder"
                                       Text="{TemplateBinding Tag}"
                                       Padding="{TemplateBinding Padding}"
                                       Foreground="{DynamicResource FgDimBrush}"
                                       FontFamily="{TemplateBinding FontFamily}"
                                       FontSize="{TemplateBinding FontSize}"
                                       VerticalAlignment="Center"
                                       IsHitTestVisible="False"
                                       Opacity="0.5"
                                       Visibility="Collapsed"/>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsFocused" Value="True">
                            <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                        </Trigger>
                        <Trigger Property="Text" Value="">
                            <Setter TargetName="placeholder" Property="Visibility" Value="Visible"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── Thin dark ScrollBar -->
    <Style TargetType="ScrollBar">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Width"      Value="6"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ScrollBar">
                    <Grid>
                        <Track x:Name="PART_Track" IsDirectionReversed="True">
                            <Track.Thumb>
                                <Thumb>
                                    <Thumb.Template>
                                        <ControlTemplate TargetType="Thumb">
                                            <Border Background="{DynamicResource BorderBrush}" CornerRadius="3"/>
                                        </ControlTemplate>
                                    </Thumb.Template>
                                </Thumb>
                            </Track.Thumb>
                        </Track>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── TabControl / TabItem (dark theme) -->
    <Style TargetType="TabControl">
        <Setter Property="Background"        Value="Transparent"/>
        <Setter Property="BorderThickness"   Value="0"/>
        <Setter Property="Padding"           Value="0"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TabControl">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <!-- Tab header strip -->
                        <Border Grid.Row="0"
                                BorderBrush="{DynamicResource NavBorderBrush}"
                                BorderThickness="0,0,0,1">
                            <TabPanel IsItemsHost="True" Background="Transparent"/>
                        </Border>
                        <!-- Content area -->
                        <Border Grid.Row="1" Background="Transparent">
                            <ContentPresenter ContentSource="SelectedContent"/>
                        </Border>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="TabItem">
        <Setter Property="Background"   Value="Transparent"/>
        <Setter Property="Foreground"   Value="{DynamicResource FgDimBrush}"/>
        <Setter Property="FontFamily"   Value="{StaticResource UiFont}"/>
        <Setter Property="FontSize"     Value="11"/>
        <Setter Property="FontWeight"   Value="Bold"/>
        <Setter Property="Cursor"       Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TabItem">
                    <Border x:Name="outer" Background="Transparent" Padding="16,10">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="3"/>
                            </Grid.RowDefinitions>
                            <ContentPresenter Grid.Row="0"
                                              ContentSource="Header"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                            <Border x:Name="accentLine" Grid.Row="1"
                                    Background="Transparent" Margin="-16,0"/>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="outer" Property="Background" Value="{DynamicResource AccentFaintBrush}"/>
                            <Setter Property="Foreground" Value="{DynamicResource FgBrush}"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="accentLine" Property="Background"
                                    Value="{DynamicResource AccentBrush}"/>
                            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── TreeView / TreeViewItem: force dark theme foreground so system colors don't bleed in -->
    <Style TargetType="TreeView">
        <Setter Property="Background"       Value="Transparent"/>
        <Setter Property="BorderThickness"  Value="0"/>
        <Setter Property="Foreground"       Value="{DynamicResource FgBrush}"/>
    </Style>

    <Style TargetType="TreeViewItem">
        <Setter Property="Foreground"   Value="{DynamicResource FgBrush}"/>
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        <Setter Property="Background"   Value="Transparent"/>
        <Setter Property="FontFamily"   Value="{StaticResource UiFont}"/>
        <Setter Property="Padding"      Value="2,2"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TreeViewItem">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="22"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <ToggleButton x:Name="Expander" Grid.Row="0" Grid.Column="0"
                                      Focusable="False" ClickMode="Press"
                                      VerticalAlignment="Center" HorizontalAlignment="Center"
                                      IsChecked="{Binding IsExpanded, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                            <ToggleButton.Template>
                                <ControlTemplate TargetType="ToggleButton">
                                    <Border Background="Transparent" Width="18" Height="18">
                                        <TextBlock x:Name="chev" Text="&#x25B8;" FontSize="10"
                                                   Foreground="{DynamicResource FgDimBrush}"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsChecked" Value="True">
                                            <Setter TargetName="chev" Property="Text" Value="&#x25BE;"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </ToggleButton.Template>
                        </ToggleButton>
                        <Border x:Name="HeaderBorder" Grid.Row="0" Grid.Column="1"
                                Background="{TemplateBinding Background}">
                            <ContentPresenter ContentSource="Header" HorizontalAlignment="Stretch" VerticalAlignment="Center"/>
                        </Border>
                        <ItemsPresenter x:Name="ItemsHost" Grid.Row="1" Grid.Column="1"/>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsExpanded" Value="False">
                            <Setter TargetName="ItemsHost" Property="Visibility" Value="Collapsed"/>
                        </Trigger>
                        <Trigger Property="HasItems" Value="False">
                            <Setter TargetName="Expander" Property="Visibility" Value="Hidden"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="{DynamicResource AccentDimBrush}"/>
            </Trigger>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource HighlightBrush}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ── StatusPill: RadioButton styled as a pill for work order status -->
    <Style x:Key="StatusPill" TargetType="RadioButton">
        <Setter Property="Background"      Value="{DynamicResource Bg3Brush}"/>
        <Setter Property="Foreground"      Value="{DynamicResource FgDimBrush}"/>
        <Setter Property="BorderBrush"     Value="{DynamicResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding"         Value="12,5"/>
        <Setter Property="FontFamily"      Value="{StaticResource UiFont}"/>
        <Setter Property="FontSize"        Value="11"/>
        <Setter Property="FontWeight"      Value="Bold"/>
        <Setter Property="Cursor"          Value="Hand"/>
        <Setter Property="Margin"          Value="0,0,6,0"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RadioButton">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="4"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                            <Setter Property="Foreground" Value="{DynamicResource FgBrush}"/>
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="border" Property="Background" Value="{DynamicResource AccentDimBrush}"/>
                            <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── NexusComboBox: dark styled ComboBox -->
    <Style x:Key="NexusComboBox" TargetType="ComboBox">
        <Setter Property="Background"      Value="{DynamicResource Bg2NavBrush}"/>
        <Setter Property="Foreground"      Value="{DynamicResource FgBrush}"/>
        <Setter Property="BorderBrush"     Value="{DynamicResource NavBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding"         Value="10,8"/>
        <Setter Property="FontFamily"      Value="{StaticResource UiFont}"/>
        <Setter Property="FontSize"        Value="{StaticResource FontMd}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBox">
                    <Grid>
                        <ToggleButton x:Name="toggleBtn"
                                      Focusable="False"
                                      IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                      ClickMode="Press">
                            <ToggleButton.Template>
                                <ControlTemplate TargetType="ToggleButton">
                                    <Border x:Name="border"
                                            Background="{DynamicResource Bg2NavBrush}"
                                            BorderBrush="{DynamicResource NavBorderBrush}"
                                            BorderThickness="1" CornerRadius="4">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="24"/>
                                            </Grid.ColumnDefinitions>
                                            <ContentPresenter Grid.Column="0"
                                                              Margin="10,8" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="1" Text="▾"
                                                       Foreground="{DynamicResource FgDimBrush}"
                                                       VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                        </Grid>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsChecked" Value="True">
                                            <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </ToggleButton.Template>
                        </ToggleButton>
                        <ContentPresenter x:Name="contentPresenter"
                                          Content="{TemplateBinding SelectionBoxItem}"
                                          ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                          Margin="10,8,30,8"
                                          VerticalAlignment="Center"
                                          IsHitTestVisible="False"/>
                        <Popup x:Name="PART_Popup"
                               IsOpen="{TemplateBinding IsDropDownOpen}"
                               Placement="Bottom" AllowsTransparency="True"
                               Focusable="False" PopupAnimation="Slide">
                            <Border Background="{DynamicResource Bg2NavBrush}"
                                    BorderBrush="{DynamicResource NavBorderBrush}"
                                    BorderThickness="1" CornerRadius="0,0,6,6"
                                    MinWidth="{TemplateBinding ActualWidth}">
                                <ScrollViewer MaxHeight="200">
                                    <ItemsPresenter/>
                                </ScrollViewer>
                            </Border>
                        </Popup>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Resources>
            <Style TargetType="ComboBoxItem">
                <Setter Property="Foreground"  Value="{DynamicResource FgBrush}"/>
                <Setter Property="Background"  Value="Transparent"/>
                <Setter Property="Padding"     Value="10,6"/>
                <Setter Property="FontFamily"  Value="{StaticResource UiFont}"/>
                <Setter Property="FontSize"    Value="{StaticResource FontMd}"/>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="{DynamicResource HighlightBrush}"/>
                    </Trigger>
                    <Trigger Property="IsSelected" Value="True">
                        <Setter Property="Background" Value="{DynamicResource AccentDimBrush}"/>
                        <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                    </Trigger>
                </Style.Triggers>
            </Style>
        </Style.Resources>
    </Style>

    <!-- ── ListView row style -->
    <Style x:Key="NexusListViewItem" TargetType="ListViewItem">
        <Setter Property="Background"   Value="Transparent"/>
        <Setter Property="Foreground"   Value="{DynamicResource FgBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding"      Value="8,4"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListViewItem">
                    <Border x:Name="bd" Background="{TemplateBinding Background}"
                            Padding="{TemplateBinding Padding}" CornerRadius="4" SnapsToDevicePixels="True">
                        <ContentPresenter/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource HighlightBrush}"/>
            </Trigger>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="{DynamicResource AccentDimBrush}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ════ Command-center vocabulary (UI overhaul): reusable text + surface styles ════ -->

    <!-- Eyebrow: small uppercase teal kicker above a page title -->
    <Style x:Key="Eyebrow" TargetType="TextBlock">
        <Setter Property="FontFamily"  Value="{StaticResource UiFont}"/>
        <Setter Property="FontSize"    Value="10.5"/>
        <Setter Property="FontWeight"  Value="Bold"/>
        <Setter Property="Foreground"  Value="{DynamicResource AccentBrush}"/>
    </Style>

    <!-- PageTitle: large Rajdhani display heading (page H1) -->
    <Style x:Key="PageTitle" TargetType="TextBlock">
        <Setter Property="FontFamily"  Value="{StaticResource DisplayFont}"/>
        <Setter Property="FontSize"    Value="26"/>
        <Setter Property="FontWeight"  Value="Bold"/>
        <Setter Property="Foreground"  Value="{DynamicResource FgBrush}"/>
        <Setter Property="Margin"      Value="0,3,0,0"/>
    </Style>

    <!-- PageSubtitle: dim one-line description under a page title (matches Hud.Header) -->
    <Style x:Key="PageSubtitle" TargetType="TextBlock">
        <Setter Property="FontFamily"  Value="{StaticResource UiFont}"/>
        <Setter Property="FontSize"    Value="12.5"/>
        <Setter Property="Foreground"  Value="{DynamicResource FgDimBrush}"/>
        <Setter Property="Margin"      Value="0,4,0,0"/>
    </Style>

    <!-- ChamferPanel: XAML MOBIGLAS chamfered panel (TL+BR bevel) + optional amber brackets.
         Mirrors the code-built Hud.Panel so XAML surfaces share the same silhouette. -->
    <Style TargetType="{x:Type views:ChamferPanel}">
        <Setter Property="Background"  Value="{DynamicResource Bg2NavBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource NavBorderBrush}"/>
        <Setter Property="Padding"     Value="16"/>
        <Setter Property="Focusable"   Value="False"/>
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        <Setter Property="VerticalContentAlignment"   Value="Stretch"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type views:ChamferPanel}">
                    <Grid>
                        <Path x:Name="PART_Frame" Fill="{TemplateBinding Background}"
                              Stroke="{TemplateBinding BorderBrush}" StrokeThickness="1" SnapsToDevicePixels="True"/>
                        <ContentPresenter x:Name="PART_Content" Margin="{TemplateBinding Padding}"
                                          HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        <Grid x:Name="PART_Brackets" IsHitTestVisible="False" Margin="2" Visibility="Collapsed">
                            <Grid.Effect>
                                <DropShadowEffect Color="{DynamicResource AccentColor}" BlurRadius="4" ShadowDepth="0" Opacity="0.5"/>
                            </Grid.Effect>
                            <Border Width="11" Height="11" HorizontalAlignment="Right" VerticalAlignment="Top"
                                    BorderBrush="{DynamicResource AccentHoverBrush}" BorderThickness="0,1.5,1.5,0"/>
                            <Border Width="11" Height="11" HorizontalAlignment="Left" VerticalAlignment="Bottom"
                                    BorderBrush="{DynamicResource AccentHoverBrush}" BorderThickness="1.5,0,0,1.5"/>
                        </Grid>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="ShowBrackets" Value="True">
                            <Setter TargetName="PART_Brackets" Property="Visibility" Value="Visible"/>
                        </Trigger>
                        <Trigger Property="Accent" Value="True">
                            <!-- Border: amber at the top-left corner fading to the slate line color.
                                 Mock .panel.accent .panel-frame = linear-gradient(135deg, amber 0%, #22303E 38%). -->
                            <Setter TargetName="PART_Frame" Property="Stroke">
                                <Setter.Value>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="{DynamicResource AccentColor}" Offset="0"/>
                                        <GradientStop Color="#FF22303E" Offset="0.38"/>
                                        <GradientStop Color="#FF22303E" Offset="1"/>
                                    </LinearGradientBrush>
                                </Setter.Value>
                            </Setter>
                            <!-- Inner: barely-there amber wash at the top fading to the dark panel base.
                                 Mock .panel-inner = linear-gradient(180deg, amber@7%, bg2 60%) (opaque equivalent). -->
                            <Setter TargetName="PART_Frame" Property="Fill">
                                <Setter.Value>
                                    <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                                        <GradientStop Color="#FF1F1F1E" Offset="0"/>
                                        <GradientStop Color="{DynamicResource Bg3Color}" Offset="0.6"/>
                                    </LinearGradientBrush>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Chamfer converter: [ActualWidth, ActualHeight] + ConverterParameter(px) -> TL+BR bevel Geometry.
         Lets the chamfered Button / TextBox templates below draw a bevelled frame Path that tracks size,
         sharing ChamferPanel's silhouette without per-control code-behind. Defined before its users. -->
    <conv:ChamferGeometryConverter x:Key="ChamferGeo"/>

    <!-- ChamferTextBox: NexusTextBox with a bevelled frame (mock .field.cham, ~9px) instead of rounded. -->
    <Style x:Key="ChamferTextBox" TargetType="TextBox" BasedOn="{StaticResource NexusTextBox}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Grid>
                        <Path x:Name="frame" Fill="{TemplateBinding Background}"
                              Stroke="{TemplateBinding BorderBrush}" StrokeThickness="1" SnapsToDevicePixels="True"
                              HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                            <Path.Data>
                                <MultiBinding Converter="{StaticResource ChamferGeo}" ConverterParameter="9">
                                    <Binding Path="ActualWidth"  RelativeSource="{RelativeSource TemplatedParent}"/>
                                    <Binding Path="ActualHeight" RelativeSource="{RelativeSource TemplatedParent}"/>
                                </MultiBinding>
                            </Path.Data>
                        </Path>
                        <ScrollViewer x:Name="PART_ContentHost" Padding="{TemplateBinding Padding}" VerticalAlignment="Center"/>
                        <TextBlock x:Name="placeholder" Text="{TemplateBinding Tag}" Padding="{TemplateBinding Padding}"
                                   Foreground="{DynamicResource FgDimBrush}" FontFamily="{TemplateBinding FontFamily}"
                                   FontSize="{TemplateBinding FontSize}" VerticalAlignment="Center"
                                   IsHitTestVisible="False" Opacity="0.5" Visibility="Collapsed"/>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsFocused" Value="True">
                            <Setter TargetName="frame" Property="Stroke" Value="{DynamicResource AccentBrush}"/>
                        </Trigger>
                        <Trigger Property="Text" Value="">
                            <Setter TargetName="placeholder" Property="Visibility" Value="Visible"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ChamferButton: ghost button with a bevelled frame (mock .btn.cham, ~7px). Hover = amber stroke. -->
    <Style x:Key="ChamferButton" TargetType="Button" BasedOn="{StaticResource NexusButton}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid>
                        <Path x:Name="frame" Fill="{TemplateBinding Background}"
                              Stroke="{TemplateBinding BorderBrush}" StrokeThickness="1" SnapsToDevicePixels="True"
                              HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                            <Path.Data>
                                <MultiBinding Converter="{StaticResource ChamferGeo}" ConverterParameter="7">
                                    <Binding Path="ActualWidth"  RelativeSource="{RelativeSource TemplatedParent}"/>
                                    <Binding Path="ActualHeight" RelativeSource="{RelativeSource TemplatedParent}"/>
                                </MultiBinding>
                            </Path.Data>
                        </Path>
                        <ContentPresenter Margin="{TemplateBinding Padding}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="frame" Property="Stroke" Value="{DynamicResource AccentBrush}"/>
                            <Setter Property="Foreground" Value="{DynamicResource FgBrush}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="frame" Property="Opacity" Value="0.75"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ChamferAccentButton: amber primary button with a bevelled frame + glow (mock .btn.amber.cham). -->
    <Style x:Key="ChamferAccentButton" TargetType="Button" BasedOn="{StaticResource AccentButton}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid>
                        <Path x:Name="frame" Fill="{TemplateBinding Background}" SnapsToDevicePixels="True"
                              HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                            <Path.Effect>
                                <DropShadowEffect Color="{DynamicResource AccentColor}" BlurRadius="16" ShadowDepth="0" Opacity="0.40"/>
                            </Path.Effect>
                            <Path.Data>
                                <MultiBinding Converter="{StaticResource ChamferGeo}" ConverterParameter="7">
                                    <Binding Path="ActualWidth"  RelativeSource="{RelativeSource TemplatedParent}"/>
                                    <Binding Path="ActualHeight" RelativeSource="{RelativeSource TemplatedParent}"/>
                                </MultiBinding>
                            </Path.Data>
                        </Path>
                        <ContentPresenter Margin="{TemplateBinding Padding}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="frame" Property="Fill" Value="{DynamicResource AccentHoverBrush}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="frame" Property="Fill" Value="{DynamicResource AccentPressBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============================================================
         WRIST-OS APP DOCK (nav mock #31): clean line glyphs + chamfered dock tiles.
         ============================================================ -->
    <!-- Monochrome 24x24 line glyphs (stroke, no fill) for each module. -->
    <PathGeometry x:Key="GlyphOps"       Figures="M3,3 H14 V10 H3 Z M16,3 H21 V10 H16 Z M3,12 H8 V21 H3 Z M10,12 H21 V21 H10 Z"/>
    <PathGeometry x:Key="GlyphRs"        Figures="M5,9 L5,5 L9,5 M15,5 L19,5 L19,9 M5,15 L5,19 L9,19 M15,19 L19,19 L19,15 M4,12 L20,12"/>
    <PathGeometry x:Key="GlyphRefinery"  Figures="M6 12 L18 12 L16 19 Q15.5 20 14.5 20 L9.5 20 Q8.5 20 8 19 Z M6,12 A6,1.6 0 1 1 18,12 A6,1.6 0 1 1 6,12 Z M9 10 C8 8.7 10 7.8 9 6.5 M12 10 C11 8.7 13 7.8 12 6.5 M15 10 C14 8.7 16 7.8 15 6.5"/>
    <PathGeometry x:Key="GlyphCodex"     Figures="M5,6 A7,2.4 0 1 1 19,6 A7,2.4 0 1 1 5,6 Z M5 6 L5 18 C5 19.5 8.1 20.6 12 20.6 C15.9 20.6 19 19.5 19 18 L19 6 M5 11.5 C5 13 8.1 14.1 12 14.1 C15.9 14.1 19 13 19 11.5"/>
    <PathGeometry x:Key="GlyphBlueprint" Figures="M12,3 L20,7.5 L20,16.5 L12,21 L4,16.5 L4,7.5 Z M12 12V3M12 12L4 16.5M12 12L20 16.5"/>
    <PathGeometry x:Key="GlyphNetwork"   Figures="M3.5,12 A2,2 0 1 1 7.5,12 A2,2 0 1 1 3.5,12 Z M16,5 A2,2 0 1 1 20,5 A2,2 0 1 1 16,5 Z M16,19 A2,2 0 1 1 20,19 A2,2 0 1 1 16,19 Z M7.2,11 L16.3,6 M7.2,13 L16.3,18"/>
    <PathGeometry x:Key="GlyphCargo"     Figures="M3,8 H13 V18 H3 Z M3,11 L13,11 M13,13 L20,13 M17,10 L20,13 L17,16"/>
    <PathGeometry x:Key="GlyphSettings"  Figures="M13.83,7.71 L13.83,10.29 L11.86,10.65 L12.54,12.54 L10.29,13.83 L9,12.3 L7.71,13.83 L5.46,12.54 L6.14,10.65 L4.17,10.29 L4.17,7.71 L6.14,7.35 L5.46,5.46 L7.71,4.17 L9,5.7 L10.29,4.17 L12.54,5.46 L11.86,7.35 Z M7.7,9 A1.3,1.3 0 1 1 10.3,9 A1.3,1.3 0 1 1 7.7,9 Z M19.56,16.59 L18.47,18.47 L16.9,17.92 L16.59,19.56 L14.41,19.56 L14.1,17.92 L12.53,18.47 L11.44,16.59 L12.7,15.5 L11.44,14.41 L12.53,12.53 L14.1,13.08 L14.41,11.44 L16.59,11.44 L16.9,13.08 L18.47,12.53 L19.56,14.41 L18.3,15.5 Z M14.4,15.5 A1.1,1.1 0 1 1 16.6,15.5 A1.1,1.1 0 1 1 14.4,15.5 Z"/>

    <!-- DockTile: a chamfered app-dock module button (RadioButton). Foreground drives glyph + name +
         chip border (dim default, amber on hover/active). Hover slides 3px; active grows an amber left
         bar in. The chip + name + optional pill are supplied as the tile's Content. -->
    <Style x:Key="DockTile" TargetType="RadioButton">
        <Setter Property="Background"  Value="{DynamicResource Bg2NavBrush}"/>
        <Setter Property="Foreground"  Value="{DynamicResource FgDimBrush}"/>
        <Setter Property="Cursor"      Value="Hand"/>
        <Setter Property="Margin"      Value="0,0,0,7"/>
        <Setter Property="Padding"     Value="11,8"/>
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RadioButton">
                    <Grid RenderTransformOrigin="0,0.5">
                        <Grid.RenderTransform><TranslateTransform x:Name="slide"/></Grid.RenderTransform>
                        <Path x:Name="frame" Fill="{TemplateBinding Background}"
                              Stroke="{DynamicResource NavBorderBrush}" StrokeThickness="1" SnapsToDevicePixels="True"
                              HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                            <Path.Data>
                                <MultiBinding Converter="{StaticResource ChamferGeo}" ConverterParameter="9">
                                    <Binding Path="ActualWidth"  RelativeSource="{RelativeSource TemplatedParent}"/>
                                    <Binding Path="ActualHeight" RelativeSource="{RelativeSource TemplatedParent}"/>
                                </MultiBinding>
                            </Path.Data>
                        </Path>
                        <ContentPresenter Margin="{TemplateBinding Padding}" VerticalAlignment="Center"/>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="frame" Property="Fill" Value="{DynamicResource Bg3Brush}"/>
                            <Setter TargetName="frame" Property="Stroke" Value="{DynamicResource AccentStrongBrush}"/>
                            <Trigger.EnterActions>
                                <BeginStoryboard><Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="slide" Storyboard.TargetProperty="X" To="3" Duration="0:0:0.16" EasingFunction="{StaticResource EaseSlideOut}"/>
                                </Storyboard></BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard><Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="slide" Storyboard.TargetProperty="X" To="0" Duration="0:0:0.16" EasingFunction="{StaticResource EaseSlideOut}"/>
                                </Storyboard></BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="frame" Property="Stroke" Value="{DynamicResource AccentBrush}"/>
                            <Setter TargetName="frame" Property="Fill">
                                <Setter.Value>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="{DynamicResource AccentFaintColor}" Offset="0"/>
                                        <GradientStop Color="{DynamicResource Bg2NavColor}" Offset="0.7"/>
                                    </LinearGradientBrush>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- DockChip: 40px chamfered glyph holder. Dark default; amber-filled when its tile is active. -->
    <Style x:Key="DockChip" TargetType="views:ChamferPanel" BasedOn="{StaticResource {x:Type views:ChamferPanel}}">
        <Setter Property="Chamfer" Value="7"/>
        <Setter Property="Width"   Value="40"/>
        <Setter Property="Height"  Value="40"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Background"  Value="{DynamicResource BgBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource NavBorderBrush}"/>
        <Style.Triggers>
            <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=RadioButton}}" Value="True">
                <Setter Property="BorderBrush" Value="{DynamicResource AccentStrongBrush}"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding IsChecked, RelativeSource={RelativeSource AncestorType=RadioButton}}" Value="True">
                <!-- Soft amber tint: translucent fill + .42 amber border (no solid-amber invert). -->
                <Setter Property="Background"  Value="{DynamicResource AccentDimBrush}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource AccentStrongBrush}"/>
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <!-- DockGlyph: line-glyph Path in a chip. Dim default, amber on hover, dark on active (amber chip). -->
    <Style x:Key="DockGlyph" TargetType="Path">
        <Setter Property="Fill" Value="{x:Null}"/>
        <Setter Property="StrokeThickness" Value="1.6"/>
        <Setter Property="StrokeStartLineCap" Value="Round"/>
        <Setter Property="StrokeEndLineCap" Value="Round"/>
        <Setter Property="StrokeLineJoin" Value="Round"/>
        <Setter Property="Stroke" Value="{DynamicResource FgDimBrush}"/>
        <Style.Triggers>
            <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=RadioButton}}" Value="True">
                <Setter Property="Stroke" Value="{DynamicResource AccentBrush}"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding IsChecked, RelativeSource={RelativeSource AncestorType=RadioButton}}" Value="True">
                <Setter Property="Stroke" Value="{DynamicResource OnAccentBrush}"/>
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <!-- DockTileName: module name. Dim default, bright when hovered or active. -->
    <Style x:Key="DockTileName" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource UiFont}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="FontSize"   Value="12.5"/>
        <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
        <Setter Property="Foreground" Value="{DynamicResource FgDimBrush}"/>
        <Style.Triggers>
            <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=RadioButton}}" Value="True">
                <Setter Property="Foreground" Value="{DynamicResource FgBrush}"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding IsChecked, RelativeSource={RelativeSource AncestorType=RadioButton}}" Value="True">
                <Setter Property="Foreground" Value="{DynamicResource FgBrush}"/>
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <!-- SectionLabel: small uppercase dim label for panel headers / KPI keys -->
    <Style x:Key="SectionLabel" TargetType="TextBlock">
        <Setter Property="FontFamily"  Value="{StaticResource UiFont}"/>
        <Setter Property="FontSize"    Value="10"/>
        <Setter Property="FontWeight"  Value="Bold"/>
        <Setter Property="Foreground"  Value="{DynamicResource FgDimBrush}"/>
    </Style>

    <!-- DataText: tabular JetBrains Mono for numbers/values -->
    <Style x:Key="DataText" TargetType="TextBlock">
        <Setter Property="FontFamily"  Value="{StaticResource MonoFont}"/>
        <Setter Property="Foreground"  Value="{DynamicResource FgBrush}"/>
    </Style>

    <!-- KpiValue: big Rajdhani readout for dashboard KPI cards -->
    <Style x:Key="KpiValue" TargetType="TextBlock">
        <Setter Property="FontFamily"  Value="{StaticResource DisplayFont}"/>
        <Setter Property="FontSize"    Value="30"/>
        <Setter Property="FontWeight"  Value="Bold"/>
        <Setter Property="Foreground"  Value="{DynamicResource FgBrush}"/>
    </Style>

    <!-- Card / Panel: the HUD surface (sharp 4px corners, faint cyan hairline) -->
    <Style x:Key="Card" TargetType="Border">
        <Setter Property="Background"      Value="{DynamicResource Bg2NavBrush}"/>
        <Setter Property="BorderBrush"     Value="{DynamicResource NavBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius"    Value="4"/>
        <Setter Property="Padding"         Value="16"/>
    </Style>

    <!-- HudCard: an accented panel that carries the amber-line + soft glow signature.
         Use for hero / primary readout surfaces (Operations hero, RS Decoder readout). -->
    <Style x:Key="HudCard" TargetType="Border" BasedOn="{StaticResource Card}">
        <Setter Property="BorderBrush" Value="{DynamicResource AccentStrongBrush}"/>
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect Color="{DynamicResource AccentColor}" BlurRadius="22" ShadowDepth="0" Opacity="0.22"/>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
