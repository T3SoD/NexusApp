<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ══ CLASSIC (v4) palette - GitHub-slate + teal + amber logo ══ -->
    <Color x:Key="BgColor">#FF0D1117</Color>
    <Color x:Key="Bg2Color">#FF161B22</Color>
    <Color x:Key="Bg3Color">#FF21262D</Color>
    <Color x:Key="BorderColor">#FF30363D</Color>
    <Color x:Key="NavBorderColor">#FF152030</Color>
    <Color x:Key="FgColor">#FFE6EDF3</Color>
    <Color x:Key="FgDimColor">#FF8B949E</Color>
    <Color x:Key="AccentColor">#FF00C9A7</Color>
    <Color x:Key="AccentDimColor">#FF0D3028</Color>
    <Color x:Key="GoldColor">#FFE8A23A</Color>
    <Color x:Key="NavBgColor">#FF070B12</Color>
    <Color x:Key="PageBgColor">#FF0A1020</Color>
    <Color x:Key="Bg2NavColor">#FF0D1828</Color>
    <Color x:Key="HighlightColor">#FF1C2128</Color>

    <!-- accent-derived (alpha variants) -->
    <Color x:Key="AccentClearColor">#0000C9A7</Color>
    <Color x:Key="AccentFaintColor">#1A00C9A7</Color>
    <Color x:Key="AccentTintColor">#2600C9A7</Color>
    <Color x:Key="AccentSoftColor">#5500C9A7</Color>
    <Color x:Key="AccentGlowColor">#6600C9A7</Color>
    <Color x:Key="AccentStrongColor">#9900C9A7</Color>
    <Color x:Key="AccentHoverColor">#FF2EE0C0</Color>
    <Color x:Key="AccentPressColor">#FF00A089</Color>
    <Color x:Key="OnAccentColor">#FF04140F</Color>

    <!-- ice-cyan secondary + semantic (parity with the MOBIGLAS palette so
         theme-switching never leaves a DynamicResource unresolved) -->
    <Color x:Key="CyanColor">#FF39D0C4</Color>
    <Color x:Key="CyanDimColor">#2439D0C4</Color>
    <Color x:Key="CyanLineColor">#1A39D0C4</Color>
    <Color x:Key="CyanGlowColor">#4439D0C4</Color>
    <Color x:Key="DangerColor">#FFF85149</Color>
    <Color x:Key="OkColor">#FF3FB950</Color>
    <Color x:Key="WarnColor">#FFE8A23A</Color>

    <!-- overlay panel gradient -->
    <Color x:Key="OverlayBgTopColor">#F20D1828</Color>
    <Color x:Key="OverlayBgBotColor">#F2070B12</Color>
</ResourceDictionary>
