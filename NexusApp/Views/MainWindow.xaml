<Window x:Class="NexusApp.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:NexusApp.ViewModels"
        xmlns:conv="clr-namespace:NexusApp.Converters"
        xmlns:models="clr-namespace:NexusApp.Models"
        xmlns:views="clr-namespace:NexusApp.Views"
        Title="Nexus" Icon="/Assets/nexus_icon_classic.png" Height="820" Width="1280"
        MinHeight="600" MinWidth="900"
        Background="{DynamicResource BgBrush}"
        Foreground="{DynamicResource FgBrush}"
        FontFamily="{StaticResource UiFont}"
        WindowStyle="SingleBorderWindow" AllowsTransparency="False"
        ResizeMode="CanResize">

    <Window.Resources>
        <conv:TierColorConverter             x:Key="TierColor"/>
        <conv:RarityColorConverter           x:Key="RarityColor"/>
        <conv:SystemColorConverter           x:Key="SystemColor"/>
        <conv:RefineryModifierColorConverter x:Key="ModColor"/>
        <conv:BoolToVisibilityConverter      x:Key="BoolVis"/>
        <conv:HexColorConverter              x:Key="HexColor"/>
        <conv:WorkOrderStatusColorConverter  x:Key="WoStatusColor"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="68"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ── Header strip (68px) - caption area for WindowChrome drag ── -->
        <Grid Grid.Row="0"
              Background="{DynamicResource NavBgBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Left: logo + title + version badges -->
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0,0,0">
                <views:NexusBeamIcon Width="28" Height="28" Margin="0,0,8,0" VerticalAlignment="Center"/>
                <StackPanel Margin="0,0,12,0" VerticalAlignment="Center">
                    <TextBlock FontFamily="{StaticResource DisplayFont}" FontSize="18" FontWeight="Bold"
                               Foreground="{StaticResource FgBrush}" VerticalAlignment="Center">
                        <Run Text="NE"/><Run Text="X" Foreground="{StaticResource AccentBrush}"/><Run Text="US"/>
                        <TextBlock.Effect>
                            <DropShadowEffect Color="{DynamicResource AccentColor}" BlurRadius="9" ShadowDepth="0" Opacity="0.3"/>
                        </TextBlock.Effect>
                    </TextBlock>
                </StackPanel>

                <!-- App version badge - clickable easter egg. Leads the strip: app -> game -> shard -> session. -->
                <Border x:Name="AppVersionBadge"
                        Padding="10,3" CornerRadius="4" Margin="0,0,6,0"
                        Background="Transparent"
                        BorderBrush="{StaticResource AccentDimBrush}"
                        BorderThickness="1"
                        Cursor="Hand"
                        MouseLeftButtonDown="AppBadge_Click">
                    <TextBlock x:Name="AppVersionText" FontSize="9"
                               Foreground="{StaticResource AccentBrush}"
                               FontWeight="Bold"
                               VerticalAlignment="Center"/>
                </Border>
                <!-- GAME version chip -->
                <Border Padding="10,3" CornerRadius="4" Margin="0,0,6,0"
                        Background="{StaticResource Bg2NavBrush}"
                        BorderBrush="{StaticResource NavBorderBrush}"
                        BorderThickness="1">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="GAME" FontSize="9" FontWeight="Bold" Foreground="{StaticResource FgDimBrush}" VerticalAlignment="Center" Margin="0,0,7,0"/>
                        <TextBlock x:Name="GameVersionText" FontSize="10" FontFamily="{StaticResource MonoFont}"
                                   Foreground="{StaticResource GoldBrush}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>
                <!-- SHARD telemetry chip (live from App.Shards) -->
                <Border Padding="9,3,11,3" CornerRadius="4" Margin="0,0,6,0"
                        Background="{StaticResource Bg2NavBrush}"
                        BorderBrush="{StaticResource NavBorderBrush}" BorderThickness="1">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Ellipse x:Name="ShardDot" Width="7" Height="7" Fill="{StaticResource FgDimBrush}" Margin="0,0,7,0" VerticalAlignment="Center"/>
                        <TextBlock Text="SHARD" FontSize="9" FontWeight="Bold" Foreground="{StaticResource FgDimBrush}" VerticalAlignment="Center" Margin="0,0,7,0"/>
                        <TextBlock x:Name="ShardChipText" Text="..." FontFamily="{StaticResource MonoFont}" FontSize="10" Foreground="{StaticResource FgBrush}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>
                <!-- SESSION telemetry chip: Game.log tracking is always on (green = monitoring, red = no log) -->
                <Border x:Name="SessionChip" Padding="9,3,11,3" CornerRadius="4" Margin="0,0,6,0"
                        Background="{StaticResource Bg2NavBrush}"
                        BorderBrush="{StaticResource NavBorderBrush}" BorderThickness="1"
                        ToolTip="Star Citizen session tracking (always on)">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Ellipse x:Name="SessionDot" Width="7" Height="7" Fill="{StaticResource FgDimBrush}" Margin="0,0,7,0" VerticalAlignment="Center"/>
                        <TextBlock Text="GAME SESSION" FontSize="9" FontWeight="Bold" Foreground="{StaticResource FgDimBrush}" VerticalAlignment="Center" Margin="0,0,7,0"/>
                        <TextBlock x:Name="SessionChipText" Text="..." FontFamily="{StaticResource MonoFont}" FontSize="10" Foreground="{StaticResource FgBrush}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>
                <!-- BLUEPRINTS telemetry chip: Auto-Track Blueprints is always on (green = tracking, red = off) -->
                <Border x:Name="BlueprintChip" Padding="9,3,11,3" CornerRadius="4" Margin="0,0,6,0"
                        Background="{StaticResource Bg2NavBrush}"
                        BorderBrush="{StaticResource NavBorderBrush}" BorderThickness="1"
                        ToolTip="Auto-Track Blueprints: collects blueprints you unlock to your library (always on)">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Ellipse x:Name="BlueprintDot" Width="7" Height="7" Fill="{StaticResource FgDimBrush}" Margin="0,0,7,0" VerticalAlignment="Center"/>
                        <TextBlock Text="BLUEPRINTS" FontSize="9" FontWeight="Bold" Foreground="{StaticResource FgDimBrush}" VerticalAlignment="Center" Margin="0,0,7,0"/>
                        <TextBlock x:Name="BlueprintChipText" Text="..." FontFamily="{StaticResource MonoFont}" FontSize="10" Foreground="{StaticResource FgBrush}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>
                <!-- SCAN telemetry chip (auto-scan state) -->
                <Border Padding="10,3" CornerRadius="4" Margin="0,0,6,0"
                        Background="{StaticResource Bg2NavBrush}"
                        BorderBrush="{StaticResource NavBorderBrush}" BorderThickness="1">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="SCAN" FontSize="9" FontWeight="Bold" Foreground="{StaticResource FgDimBrush}" VerticalAlignment="Center" Margin="0,0,7,0"/>
                        <TextBlock x:Name="ScanChipText" Text="off" FontSize="10" FontFamily="{StaticResource MonoFont}" Foreground="{StaticResource FgDimBrush}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>
                <!-- Easter egg hint - hidden until badge is clicked -->
                <TextBlock x:Name="EggHintLabel"
                           Text="" FontSize="9" FontStyle="Italic"
                           Foreground="{StaticResource FgDimBrush}"
                           VerticalAlignment="Center" Margin="0,0,8,0"
                           Visibility="Collapsed"/>
            </StackPanel>

            <!-- Right: OS clock + action buttons -->
            <StackPanel Grid.Column="1" Orientation="Horizontal"
                        VerticalAlignment="Center" Margin="0,0,8,0">
                <TextBlock x:Name="OsClock" Text="00:00:00" FontFamily="{StaticResource MonoFont}" FontSize="13"
                           Foreground="{DynamicResource FgBrush}" VerticalAlignment="Center" Margin="0,0,2,0"/>
                <TextBlock Text="STD" FontFamily="{StaticResource MonoFont}" FontSize="9"
                           Foreground="{DynamicResource FgDimBrush}" VerticalAlignment="Center" Margin="0,2,0,0"/>
                <Border Width="1" Height="18" Background="{DynamicResource NavBorderBrush}" Margin="11,0,9,0" VerticalAlignment="Center"/>
                <Button x:Name="OverlayToggleBtn" Content="⧉" ToolTip="Toggle Overlay"
                        Style="{StaticResource HeaderButton}"
                        Width="38" Height="38" Margin="2,0"
                        Click="ToggleOverlay_Click"/>
                <Button ToolTip="Shopping List"
                        Style="{StaticResource HeaderButton}"
                        Width="38" Height="38" Margin="2,0"
                        Click="ShowShopping_Click">
                    <!-- Vector cart (avoids the color emoji glyph; matches the cog pattern) -->
                    <Viewbox Width="17" Height="17">
                        <Path Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              Data="M7,18c-1.1,0-1.99,0.9-1.99,2S5.9,22,7,22s2-0.9,2-2S8.1,18,7,18z M1,2v2h2l3.6,7.59l-1.35,2.45C5.16,14.37,5,14.79,5,15.25c0,1.1,0.9,2,2,2h12v-2H7.42c-0.14,0-0.25-0.11-0.25-0.25l0.03-0.12L8.1,13h7.45c0.75,0,1.41-0.41,1.75-1.03l3.58-6.49C20.95,5.34,21,5.17,21,5c0-0.55-0.45-1-1-1H5.21L4.27,2H1z M17,18c-1.1,0-1.99,0.9-1.99,2s0.89,2,1.99,2s2-0.9,2-2S18.1,18,17,18z"/>
                    </Viewbox>
                </Button>
                <Button Content="?" ToolTip="Help"
                        Style="{StaticResource HeaderButton}"
                        Width="38" Height="38" Margin="2,0"
                        Click="Help_Click"/>
                <Button ToolTip="About"
                        Style="{StaticResource HeaderButton}"
                        Width="38" Height="38" Margin="2,0"
                        Click="About_Click">
                    <!-- Vector info circle (font glyph U+2139 renders as a color emoji in the fallback font) -->
                    <Viewbox Width="17" Height="17">
                        <Path Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              Data="M12,2C6.48,2,2,6.48,2,12s4.48,10,10,10s10-4.48,10-10S17.52,2,12,2z M13,17h-2v-6h2V17z M13,9h-2V7h2V9z"/>
                    </Viewbox>
                </Button>
            </StackPanel>

            <!-- amber OS-bar hairline -->
            <Border Grid.ColumnSpan="2" VerticalAlignment="Bottom" Height="1">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="{DynamicResource AccentClearColor}" Offset="0"/>
                        <GradientStop Color="{DynamicResource AccentGlowColor}" Offset="0.5"/>
                        <GradientStop Color="{DynamicResource AccentClearColor}" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
            </Border>
        </Grid>

        <!-- ── Body: sidebar + content ── -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="248"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ── App dock (Wrist-OS, nav mock #31) ── -->
            <Border Grid.Column="0"
                    Background="{DynamicResource NavBgBrush}"
                    BorderBrush="{DynamicResource NavBorderBrush}"
                    BorderThickness="0,0,1,0">
                <Grid Margin="12,14,12,13">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- dock head -->
                    <Grid Grid.Row="0" Margin="3,0,2,2">
                        <TextBlock Text="INSTALLED MODULES" FontFamily="{StaticResource UiFont}" FontWeight="Bold"
                                   FontSize="8.5" Foreground="{DynamicResource FgDimBrush}" VerticalAlignment="Center"/>
                        <Border HorizontalAlignment="Right" BorderBrush="{DynamicResource NavBorderBrush}" BorderThickness="1" Padding="6,1">
                            <TextBlock Text="08" FontFamily="{StaticResource MonoFont}" FontSize="10" Foreground="{DynamicResource AccentBrush}"/>
                        </Border>
                    </Grid>

                    <!-- module tiles -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,13,0,0">
                        <Grid>
                            <!-- single amber selector bar that slides to the active tile (positioned in code-behind) -->
                            <Border x:Name="DockSelector" Width="2.5" Height="40" HorizontalAlignment="Left" VerticalAlignment="Top"
                                    CornerRadius="2" Background="{DynamicResource AccentBrush}" Opacity="0" IsHitTestVisible="False">
                                <Border.RenderTransform><TranslateTransform x:Name="DockSelectorT"/></Border.RenderTransform>
                                <Border.Effect><DropShadowEffect Color="{DynamicResource AccentColor}" BlurRadius="10" ShadowDepth="0" Opacity="0.85"/></Border.Effect>
                            </Border>
                        <StackPanel x:Name="DockTiles">
                            <RadioButton x:Name="NavCommand" Tag="command" Style="{StaticResource DockTile}" IsChecked="True" Click="Nav_Click" Checked="Nav_Click">
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                    <views:ChamferPanel Grid.Column="0" Style="{StaticResource DockChip}">
                                        <views:AnimatedDockIcon IconKey="operations" Width="28" Height="28"/>
                                    </views:ChamferPanel>
                                    <StackPanel Grid.Column="1" Margin="12,0,8,0" VerticalAlignment="Center">
                                        <TextBlock Text="Operations" Style="{StaticResource DockTileName}"/>
                                        <TextBlock Text="HUD HOME" FontFamily="{StaticResource MonoFont}" FontSize="8" Foreground="{DynamicResource FgDimBrush}" Margin="0,3,0,0"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                        <Ellipse x:Name="OpsLiveDot" Width="7" Height="7" Fill="{DynamicResource OkBrush}" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                        <TextBlock x:Name="OpsLiveText" Text="LIVE" FontFamily="{StaticResource MonoFont}" FontSize="8" FontWeight="Bold" Foreground="{DynamicResource OkBrush}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Grid>
                            </RadioButton>

                            <RadioButton x:Name="NavScan" Tag="scan" Style="{StaticResource DockTile}" Click="Nav_Click" Checked="Nav_Click">
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <views:ChamferPanel Grid.Column="0" Style="{StaticResource DockChip}">
                                        <views:AnimatedDockIcon IconKey="rs" Width="28" Height="28"/>
                                    </views:ChamferPanel>
                                    <StackPanel Grid.Column="1" Margin="12,0,8,0" VerticalAlignment="Center">
                                        <TextBlock Text="RS Decoder" Style="{StaticResource DockTileName}"/>
                                        <TextBlock Text="SCANNER" FontFamily="{StaticResource MonoFont}" FontSize="8" Foreground="{DynamicResource FgDimBrush}" Margin="0,3,0,0"/>
                                    </StackPanel>
                                </Grid>
                            </RadioButton>

                            <RadioButton x:Name="NavWork" Tag="workorders" Style="{StaticResource DockTile}" Click="Nav_Click" Checked="Nav_Click">
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                    <views:ChamferPanel Grid.Column="0" Style="{StaticResource DockChip}">
                                        <views:AnimatedDockIcon IconKey="refinery" Width="28" Height="28"/>
                                    </views:ChamferPanel>
                                    <StackPanel Grid.Column="1" Margin="12,0,8,0" VerticalAlignment="Center">
                                        <TextBlock Text="Refinery" Style="{StaticResource DockTileName}"/>
                                        <TextBlock Text="PROCESSING" FontFamily="{StaticResource MonoFont}" FontSize="8" Foreground="{DynamicResource FgDimBrush}" Margin="0,3,0,0"/>
                                    </StackPanel>
                                    <Border x:Name="NavWorkPill" Grid.Column="2" VerticalAlignment="Center" CornerRadius="9" Padding="6,1"
                                            Background="{DynamicResource AccentFaintBrush}" BorderBrush="{DynamicResource AccentDimBrush}" BorderThickness="1" Visibility="Collapsed">
                                        <TextBlock x:Name="NavWorkBadge" Text="" FontFamily="{StaticResource MonoFont}" FontSize="9.5" FontWeight="Bold" Foreground="{DynamicResource AccentBrush}"/>
                                    </Border>
                                </Grid>
                            </RadioButton>

                            <RadioButton x:Name="NavRef" Tag="reference" Style="{StaticResource DockTile}" Click="Nav_Click" Checked="Nav_Click">
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <views:ChamferPanel Grid.Column="0" Style="{StaticResource DockChip}">
                                        <views:AnimatedDockIcon IconKey="codex" Width="28" Height="28"/>
                                    </views:ChamferPanel>
                                    <StackPanel Grid.Column="1" Margin="12,0,8,0" VerticalAlignment="Center">
                                        <TextBlock Text="Mining Codex" Style="{StaticResource DockTileName}"/>
                                        <TextBlock Text="ORE REFERENCE" FontFamily="{StaticResource MonoFont}" FontSize="8" Foreground="{DynamicResource FgDimBrush}" Margin="0,3,0,0"/>
                                    </StackPanel>
                                </Grid>
                            </RadioButton>

                            <RadioButton x:Name="NavBlue" Tag="blueprints" Style="{StaticResource DockTile}" Click="Nav_Click" Checked="Nav_Click">
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <views:ChamferPanel Grid.Column="0" Style="{StaticResource DockChip}">
                                        <views:AnimatedDockIcon IconKey="blueprint" Width="28" Height="28"/>
                                    </views:ChamferPanel>
                                    <StackPanel Grid.Column="1" Margin="12,0,8,0" VerticalAlignment="Center">
                                        <TextBlock Text="Blueprint Library" Style="{StaticResource DockTileName}"/>
                                        <TextBlock Text="CRAFTING" FontFamily="{StaticResource MonoFont}" FontSize="8" Foreground="{DynamicResource FgDimBrush}" Margin="0,3,0,0"/>
                                    </StackPanel>
                                </Grid>
                            </RadioButton>

                            <RadioButton x:Name="NavNetwork" Tag="network" Style="{StaticResource DockTile}" Click="Nav_Click" Checked="Nav_Click">
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <views:ChamferPanel Grid.Column="0" Style="{StaticResource DockChip}">
                                        <views:AnimatedDockIcon IconKey="network" Width="28" Height="28"/>
                                    </views:ChamferPanel>
                                    <StackPanel Grid.Column="1" Margin="12,0,8,0" VerticalAlignment="Center">
                                        <TextBlock Text="Network" Style="{StaticResource DockTileName}"/>
                                        <TextBlock Text="BLUEPRINT SHARING" FontFamily="{StaticResource MonoFont}" FontSize="8" Foreground="{DynamicResource FgDimBrush}" Margin="0,3,0,0"/>
                                    </StackPanel>
                                </Grid>
                            </RadioButton>

                            <RadioButton x:Name="NavHauling" Tag="hauling" Style="{StaticResource DockTile}" Click="Nav_Click" Checked="Nav_Click">
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                    <views:ChamferPanel Grid.Column="0" Style="{StaticResource DockChip}">
                                        <views:AnimatedDockIcon IconKey="cargo" Width="28" Height="28"/>
                                    </views:ChamferPanel>
                                    <StackPanel Grid.Column="1" Margin="12,0,8,0" VerticalAlignment="Center">
                                        <TextBlock Text="Cargo Hauling" Style="{StaticResource DockTileName}"/>
                                        <TextBlock Text="LOGISTICS" FontFamily="{StaticResource MonoFont}" FontSize="8" Foreground="{DynamicResource FgDimBrush}" Margin="0,3,0,0"/>
                                    </StackPanel>
                                    <Border x:Name="NavHaulPill" Grid.Column="2" VerticalAlignment="Center" CornerRadius="9" Padding="6,1"
                                            Background="{DynamicResource AccentFaintBrush}" BorderBrush="{DynamicResource AccentDimBrush}" BorderThickness="1" Visibility="Collapsed">
                                        <TextBlock x:Name="NavHaulBadge" Text="" FontFamily="{StaticResource MonoFont}" FontSize="9.5" FontWeight="Bold" Foreground="{DynamicResource AccentBrush}"/>
                                    </Border>
                                </Grid>
                            </RadioButton>

                            <RadioButton x:Name="NavPlanner" Tag="planner" Visibility="Collapsed" Style="{StaticResource DockTile}" Click="Nav_Click" Checked="Nav_Click">
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <views:ChamferPanel Grid.Column="0" Style="{StaticResource DockChip}">
                                        <views:AnimatedDockIcon IconKey="blueprint" Width="28" Height="28"/>
                                    </views:ChamferPanel>
                                    <StackPanel Grid.Column="1" Margin="12,0,8,0" VerticalAlignment="Center">
                                        <TextBlock Text="Cargo Planner" Style="{StaticResource DockTileName}"/>
                                        <TextBlock Text="LOADOUT" FontFamily="{StaticResource MonoFont}" FontSize="8" Foreground="{DynamicResource FgDimBrush}" Margin="0,3,0,0"/>
                                    </StackPanel>
                                </Grid>
                            </RadioButton>

                            <RadioButton x:Name="NavGridStudio" Tag="gridstudio" Visibility="Collapsed" Style="{StaticResource DockTile}" Click="Nav_Click" Checked="Nav_Click">
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <views:ChamferPanel Grid.Column="0" Style="{StaticResource DockChip}">
                                        <views:AnimatedDockIcon IconKey="blueprint" Width="28" Height="28"/>
                                    </views:ChamferPanel>
                                    <StackPanel Grid.Column="1" Margin="12,0,8,0" VerticalAlignment="Center">
                                        <TextBlock Text="Grid Studio" Style="{StaticResource DockTileName}"/>
                                        <TextBlock Text="DEV" FontFamily="{StaticResource MonoFont}" FontSize="8" Foreground="{DynamicResource FgDimBrush}" Margin="0,3,0,0"/>
                                    </StackPanel>
                                </Grid>
                            </RadioButton>

                            <RadioButton x:Name="NavSettings" Tag="settings" Style="{StaticResource DockTile}" Click="Nav_Click" Checked="Nav_Click">
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <views:ChamferPanel Grid.Column="0" Style="{StaticResource DockChip}">
                                        <views:AnimatedDockIcon IconKey="settings" Width="28" Height="28"/>
                                    </views:ChamferPanel>
                                    <StackPanel Grid.Column="1" Margin="12,0,8,0" VerticalAlignment="Center">
                                        <TextBlock Text="Settings" Style="{StaticResource DockTileName}"/>
                                        <TextBlock Text="SYSTEM" FontFamily="{StaticResource MonoFont}" FontSize="8" Foreground="{DynamicResource FgDimBrush}" Margin="0,3,0,0"/>
                                    </StackPanel>
                                </Grid>
                            </RadioButton>
                        </StackPanel>
                        </Grid>
                    </ScrollViewer>

                    <!-- dock foot: operator -->
                    <views:ChamferPanel Grid.Row="2" Chamfer="8" Padding="11,9" Margin="0,10,0,0" Background="{DynamicResource BgBrush}">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <views:ChamferPanel Chamfer="6" Width="32" Height="32" Padding="0"
                                                Background="{DynamicResource AccentFaintBrush}" BorderBrush="{DynamicResource AccentStrongBrush}">
                                <TextBlock Text="SC" FontFamily="{StaticResource DisplayFont}" FontWeight="Bold" FontSize="13"
                                           Foreground="{DynamicResource AccentBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </views:ChamferPanel>
                            <StackPanel Margin="10,0,0,0" VerticalAlignment="Center">
                                <TextBlock x:Name="OperatorName" Text="OPERATOR" FontFamily="{StaticResource UiFont}" FontWeight="Bold" FontSize="11"
                                           Foreground="{DynamicResource FgBrush}" MaxWidth="150" TextTrimming="CharacterEllipsis"/>
                                <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                    <Ellipse x:Name="LinkDot" Width="7" Height="7" Fill="{DynamicResource OkBrush}" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                    <TextBlock x:Name="LinkStatusText" Text="ONLINE . SECURE LINK" FontFamily="{StaticResource MonoFont}" FontSize="8" Foreground="{DynamicResource FgDimBrush}"/>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </views:ChamferPanel>
                </Grid>
            </Border>

            <!-- ── Viewport (Wrist-OS launched-app window, nav mock #31): chamfered amber-gradient frame
                 around a title bar + the page stage ── -->
            <Grid Grid.Column="1" Margin="14,14,16,16">
                <views:ChamferPanel Accent="True" ClipContent="True" Chamfer="18" Padding="0">
                <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="34"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- viewport title bar: run dot + module path + RUNNING + window controls + amber hairline -->
                <Grid Grid.Row="0" Background="{DynamicResource Bg2NavBrush}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="14,0,0,0">
                        <Ellipse x:Name="VpRunDot" Width="7" Height="7" Fill="{DynamicResource OkBrush}" VerticalAlignment="Center" Margin="0,0,9,0"/>
                        <TextBlock x:Name="VpModule" Text="module://nexus/command" FontFamily="{StaticResource MonoFont}"
                                   FontSize="10" Foreground="{DynamicResource FgDimBrush}" VerticalAlignment="Center"/>
                        <Border Margin="10,0,0,0" Padding="6,2" Background="{DynamicResource AccentFaintBrush}"
                                BorderBrush="{DynamicResource AccentDimBrush}" BorderThickness="1">
                            <TextBlock Text="RUNNING" FontFamily="{StaticResource MonoFont}" FontSize="8"
                                       Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center"/>
                        </Border>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,14,0">
                        <Rectangle Width="9" Height="9" Fill="{DynamicResource NavBorderBrush}" Margin="3,0"/>
                        <Rectangle Width="9" Height="9" Fill="{DynamicResource NavBorderBrush}" Margin="3,0"/>
                        <Rectangle Width="9" Height="9" Fill="{DynamicResource AccentBrush}" Margin="3,0"/>
                    </StackPanel>
                    <Border x:Name="VpUnderline" Grid.ColumnSpan="2" VerticalAlignment="Bottom" Height="1"
                            RenderTransformOrigin="0,0.5">
                        <Border.RenderTransform><ScaleTransform x:Name="VpUnderlineT" ScaleX="1"/></Border.RenderTransform>
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="{DynamicResource AccentClearColor}" Offset="0"/>
                                <GradientStop Color="{DynamicResource AccentGlowColor}" Offset="0.5"/>
                                <GradientStop Color="{DynamicResource AccentClearColor}" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>
                </Grid>

                <!-- viewport stage: the existing page content + boot/sweep overlays -->
                <Grid Grid.Row="1" Background="{DynamicResource PageBgBrush}">

                <!-- ── BLUEPRINT NETWORK PAGE (built in code - Views/NetworkPage.cs) ── -->
                <!-- ── OPERATIONS / COMMAND DASHBOARD (built in code - Views/CommandPage.cs) ── -->
                <Grid x:Name="PageCommand" Visibility="Collapsed"/>

                <Grid x:Name="PageNetwork" Visibility="Collapsed"/>

                <!-- ── CARGO HAULING PAGE (built in code - Views/HaulingPage.cs) ── -->
                <Grid x:Name="PageHauling" Visibility="Collapsed"/>
                <Grid x:Name="PagePlanner" Visibility="Collapsed"/>
                <Grid x:Name="PageGridStudio" Visibility="Collapsed"/>

                <!-- ── SETTINGS PAGE (built in code - Views/SettingsPage.cs) ── -->
                <Grid x:Name="PageSettings" Visibility="Collapsed"/>

                <!-- ── RS SIGNAL DECODER PAGE (C1 dashboard) ── -->
                <Grid x:Name="PageScan" Visibility="Visible">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Page header: teal eyebrow + display title + subtitle -->
                    <StackPanel Grid.Row="0" Margin="20,16,20,4">
                        <TextBlock Text="SIGNAL" Style="{StaticResource Eyebrow}"/>
                        <TextBlock Text="RS Decoder" Style="{StaticResource PageTitle}"/>
                        <TextBlock Text="Identify a deposit from its rock-scan RS value and match confidence." Style="{StaticResource PageSubtitle}"/>
                    </StackPanel>

                    <!-- Two-column scan body -->
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="340"/>
                        </Grid.ColumnDefinitions>

                    <!-- LEFT: scan input + hero + other matches -->
                    <Grid Grid.Column="0" Margin="20,4,16,16">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- input row -->
                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="RsInputBox" Style="{StaticResource ChamferTextBox}" FontSize="14" Height="48"
                                     Text="{Binding RsInput, UpdateSourceTrigger=PropertyChanged}"
                                     KeyDown="RsInput_KeyDown" Tag="Enter RS value…"
                                     ToolTip="Enter an RS value and press Enter"/>
                            <Button Grid.Column="1" Content="SCAN" Style="{StaticResource ChamferAccentButton}"
                                    Height="48" Width="100" Margin="8,0,0,0" FontSize="13" Command="{Binding LookupCommand}"/>
                            <Button Grid.Column="2" Content="Clear" Style="{StaticResource ChamferButton}"
                                    Height="48" Margin="6,0,0,0" Padding="16,0" Command="{Binding ClearScanCommand}"/>
                        </Grid>

                        <!-- status + legend -->
                        <views:ChamferPanel Grid.Row="1" Chamfer="10" Padding="12,8" Margin="2,10,0,0">
                            <StackPanel>
                                <TextBlock Text="{Binding StatusText}" FontSize="10" Foreground="{StaticResource FgDimBrush}" Margin="0,0,0,4"/>
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse Width="8" Height="8" Fill="#FF3FB950" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Exact" FontSize="11" Foreground="{StaticResource FgDimBrush}" Margin="0,0,12,0"/>
                                    <Ellipse Width="8" Height="8" Fill="{DynamicResource GoldBrush}" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Close match (≤0.5%)" FontSize="11" Foreground="{StaticResource FgDimBrush}" Margin="0,0,12,0"/>
                                    <TextBlock Text="RS values are patch-specific" FontSize="11" Foreground="{StaticResource FgDimBrush}"/>
                                </StackPanel>
                            </StackPanel>
                        </views:ChamferPanel>

                        <TextBlock Grid.Row="2" Text="BEST MATCH" FontSize="9" FontWeight="Bold"
                                   Foreground="{StaticResource FgDimBrush}" Margin="2,18,0,8"/>

                        <!-- hero best match -->
                        <ContentControl Grid.Row="3" Content="{Binding BestMatch}"
                                        Visibility="{Binding HasResults, Converter={StaticResource BoolVis}}">
                            <ContentControl.ContentTemplate>
                                <DataTemplate>
                                    <views:ChamferPanel Accent="True" ShowBrackets="True" Chamfer="14" Padding="20,18,20,16">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                                <Border Width="18" Height="18" CornerRadius="5" Margin="0,0,12,0" VerticalAlignment="Center"
                                                        Background="{Binding Resource.Rarity, Converter={StaticResource RarityColor}}"/>
                                                <TextBlock Text="{Binding Resource.Name}" FontFamily="{StaticResource DisplayFont}" FontSize="26" FontWeight="Bold"
                                                           Foreground="{Binding Resource.Rarity, Converter={StaticResource RarityColor}}" VerticalAlignment="Center"/>
                                                <Border Padding="6,2" CornerRadius="4" Margin="12,0,0,0" VerticalAlignment="Center" Background="{StaticResource Bg3Brush}">
                                                    <TextBlock Text="{Binding BadgeText}" FontSize="9" FontWeight="Bold"
                                                               Foreground="{StaticResource GoldBrush}"/>
                                                </Border>
                                                <Border Padding="6,2" CornerRadius="4" Margin="8,0,0,0" VerticalAlignment="Center"
                                                        Background="{DynamicResource AccentBrush}"
                                                        Visibility="{Binding IsInCart, Converter={StaticResource BoolVis}}">
                                                    <TextBlock Text="IN CART" FontSize="9" FontWeight="Bold" Foreground="{DynamicResource OnAccentBrush}"/>
                                                </Border>
                                            </StackPanel>

                                            <StackPanel Grid.Row="0" Grid.Column="1" Grid.RowSpan="2" HorizontalAlignment="Right">
                                                <TextBlock Text="RS VALUE" FontSize="9" FontWeight="Bold" HorizontalAlignment="Right"
                                                           Foreground="{StaticResource FgDimBrush}"/>
                                                <TextBlock views:CountUp.To="{Binding Resource.BaseRs}" FontFamily="{StaticResource MonoFont}"
                                                           FontSize="37" Foreground="{StaticResource CyanBrush}" HorizontalAlignment="Right">
                                                    <TextBlock.Effect>
                                                        <DropShadowEffect Color="{DynamicResource CyanColor}" BlurRadius="16" ShadowDepth="0" Opacity="0.5"/>
                                                    </TextBlock.Effect>
                                                </TextBlock>
                                            </StackPanel>

                                            <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,6,0,0" FontSize="12"
                                                       Foreground="{StaticResource FgDimBrush}" Text="{Binding NodesText}"/>

                                            <Border Grid.Row="2" Grid.ColumnSpan="2" Height="1" Background="{StaticResource NavBorderBrush}" Margin="0,10,0,0"/>

                                            <Grid Grid.Row="3" Grid.ColumnSpan="2" Margin="0,10,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                    <Ellipse Width="8" Height="8" Margin="0,0,8,0" VerticalAlignment="Center"
                                                             Fill="{Binding RefineryColor, Converter={StaticResource HexColor}}"/>
                                                    <TextBlock Text="{Binding RefineryText}" FontSize="12" Foreground="{StaticResource FgBrush}" VerticalAlignment="Center"/>
                                                </StackPanel>
                                                <Button Grid.Column="1" Content="+ Add to cart" Style="{StaticResource ChamferAccentButton}" Padding="14,7"
                                                        Command="{Binding DataContext.AddResourceToShoppingCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CommandParameter="{Binding Resource}"/>
                                            </Grid>
                                        </Grid>
                                    </views:ChamferPanel>
                                </DataTemplate>
                            </ContentControl.ContentTemplate>
                        </ContentControl>

                        <!-- empty placeholder: MOBIGLAS idle scan reticle (corner brackets + rotating ring + crosshair) -->
                        <views:ChamferPanel Grid.Row="3" Chamfer="11" Height="132" Padding="0"
                                Visibility="{Binding NoResults, Converter={StaticResource BoolVis}}">
                            <Grid>
                                <Border Width="16" Height="16" Margin="12" HorizontalAlignment="Left"  VerticalAlignment="Top"    BorderBrush="{DynamicResource AccentStrongBrush}" BorderThickness="1.5,1.5,0,0"/>
                                <Border Width="16" Height="16" Margin="12" HorizontalAlignment="Right" VerticalAlignment="Top"    BorderBrush="{DynamicResource AccentStrongBrush}" BorderThickness="0,1.5,1.5,0"/>
                                <Border Width="16" Height="16" Margin="12" HorizontalAlignment="Left"  VerticalAlignment="Bottom" BorderBrush="{DynamicResource AccentStrongBrush}" BorderThickness="1.5,0,0,1.5"/>
                                <Border Width="16" Height="16" Margin="12" HorizontalAlignment="Right" VerticalAlignment="Bottom" BorderBrush="{DynamicResource AccentStrongBrush}" BorderThickness="0,0,1.5,1.5"/>
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Grid Width="56" Height="56" HorizontalAlignment="Center">
                                        <Ellipse x:Name="ReticleRing" Width="56" Height="56" Stroke="{DynamicResource CyanGlowBrush}" StrokeThickness="1.5"
                                                 StrokeDashArray="4 3" RenderTransformOrigin="0.5,0.5">
                                            <Ellipse.RenderTransform><RotateTransform Angle="0"/></Ellipse.RenderTransform>
                                        </Ellipse>
                                        <Ellipse Width="30" Height="30" Stroke="{DynamicResource AccentBrush}" StrokeThickness="1.5" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        <Border Width="1" Height="56" Background="{DynamicResource CyanDimBrush}" HorizontalAlignment="Center"/>
                                        <Border Height="1" Width="56" Background="{DynamicResource CyanDimBrush}" VerticalAlignment="Center"/>
                                        <Ellipse Width="5" Height="5" Fill="{DynamicResource AccentBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Grid>
                                    <TextBlock Text="Scan an RS value to identify a deposit" Foreground="{StaticResource FgDimBrush}" FontSize="13" Margin="0,14,0,0" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Grid>
                        </views:ChamferPanel>

                        <TextBlock Grid.Row="4" Text="OTHER MATCHES" FontSize="9" FontWeight="Bold"
                                   Foreground="{StaticResource FgDimBrush}" Margin="2,20,0,8"
                                   Visibility="{Binding HasResults, Converter={StaticResource BoolVis}}"/>

                        <ScrollViewer Grid.Row="5" VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding OtherMatches}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <views:ChamferPanel Margin="0,0,0,8" Chamfer="9" Padding="0">
                                            <Grid Height="58">
                                                <Border Width="4" HorizontalAlignment="Left" CornerRadius="10,0,0,10"
                                                        Background="{Binding Resource.Rarity, Converter={StaticResource RarityColor}}"/>
                                                <Grid Margin="16,0,16,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel VerticalAlignment="Center">
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="{Binding Resource.Name}" FontFamily="{StaticResource HeadFont}" FontSize="16"
                                                                       Foreground="{Binding Resource.Rarity, Converter={StaticResource RarityColor}}"/>
                                                            <Border Padding="5,1" CornerRadius="4" Margin="8,0,0,0" VerticalAlignment="Center"
                                                                    Background="{DynamicResource AccentBrush}"
                                                                    Visibility="{Binding IsInCart, Converter={StaticResource BoolVis}}">
                                                                <TextBlock Text="CART" FontSize="8" FontWeight="Bold" Foreground="{DynamicResource OnAccentBrush}"/>
                                                            </Border>
                                                        </StackPanel>
                                                        <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                                                            <Border Padding="5,1" CornerRadius="3" Background="{StaticResource Bg3Brush}">
                                                                <TextBlock Text="{Binding BadgeText}" FontSize="9" FontWeight="Bold"
                                                                           Foreground="{Binding CardColor, Converter={StaticResource HexColor}}"/>
                                                            </Border>
                                                            <TextBlock Text="{Binding NodesText}" FontSize="11" Foreground="{StaticResource FgDimBrush}" Margin="8,0,0,0" VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                    </StackPanel>
                                                    <TextBlock Grid.Column="1" VerticalAlignment="Center" FontFamily="{StaticResource MonoFont}" FontSize="18"
                                                               Foreground="{StaticResource FgBrush}" Text="{Binding Resource.BaseRs, StringFormat='RS {0:N0}'}"/>
                                                    <Button Grid.Column="2" Content="Add" Style="{StaticResource ChamferButton}" Padding="10,4" Margin="12,0,0,0" VerticalAlignment="Center"
                                                            Command="{Binding DataContext.AddResourceToShoppingCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                            CommandParameter="{Binding Resource}"/>
                                                </Grid>
                                            </Grid>
                                        </views:ChamferPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>

                    <!-- RIGHT RAIL: session + recent scans -->
                    <Grid Grid.Column="1" Margin="0,4,20,16">

                        <views:ChamferPanel x:Name="ScanHistorySection" Chamfer="12" Padding="0">
                            <DockPanel>
                                <Grid DockPanel.Dock="Top" Margin="14,10,10,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="RECENT SCANS" FontSize="9" FontWeight="Bold"
                                               Foreground="{StaticResource FgDimBrush}" VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="1" x:Name="HistoryFilterPanel" Orientation="Horizontal"
                                                HorizontalAlignment="Center" VerticalAlignment="Center" Margin="8,0"/>
                                    <Button Grid.Column="2" Content="Clear" Style="{StaticResource NexusButton}"
                                            Height="20" Padding="6,0" FontSize="10" Command="{Binding ClearHistoryCommand}"/>
                                </Grid>
                                <Border DockPanel.Dock="Top" Height="1" Background="{StaticResource NavBorderBrush}"/>
                                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="6,6,6,6">
                                    <ItemsControl ItemsSource="{Binding FilteredScanHistory}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Button Margin="0" Cursor="Hand" HorizontalContentAlignment="Stretch" Click="HistoryItem_Click">
                                                    <Button.Template>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border x:Name="row" Padding="12,5,12,5" Background="Transparent" CornerRadius="6">
                                                                <Grid>
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="Auto"/>
                                                                        <ColumnDefinition Width="*"/>
                                                                        <ColumnDefinition Width="Auto"/>
                                                                    </Grid.ColumnDefinitions>
                                                                    <TextBlock Grid.Column="0" Text="◆" FontSize="10"
                                                                               Foreground="{Binding RsColor, Converter={StaticResource HexColor}}"
                                                                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                                                                        <TextBlock Text="{Binding TopResource}" FontSize="11"
                                                                                   Foreground="{StaticResource FgBrush}" Opacity="{Binding NameOpacity}"
                                                                                   VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                                                        <Border Padding="4,1" CornerRadius="3" Margin="6,0,0,0"
                                                                                Background="{DynamicResource AccentBrush}" VerticalAlignment="Center"
                                                                                Visibility="{Binding IsInCart, Converter={StaticResource BoolVis}}">
                                                                            <TextBlock Text="CART" FontSize="8" FontWeight="Bold" Foreground="{DynamicResource OnAccentBrush}"/>
                                                                        </Border>
                                                                    </StackPanel>
                                                                    <TextBlock Grid.Column="2" Text="{Binding Rs, StringFormat='RS {0:N0}'}" FontSize="11"
                                                                               Foreground="{Binding RsColor, Converter={StaticResource HexColor}}" VerticalAlignment="Center"/>
                                                                </Grid>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <DataTrigger Binding="{Binding IsInCart}" Value="True">
                                                                    <Setter TargetName="row" Property="Background" Value="{DynamicResource AccentFaintBrush}"/>
                                                                </DataTrigger>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="row" Property="Background" Value="{StaticResource HighlightBrush}"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Button.Template>
                                                </Button>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </DockPanel>
                        </views:ChamferPanel>
                    </Grid>
                    </Grid>
                </Grid>

                <!-- ── BLUEPRINT PAGE ── -->
                <Grid x:Name="PageBlueprints" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Page header: teal eyebrow + display title + ambient schematic glyph -->
                    <Grid Grid.Row="0" Margin="20,16,20,6">
                        <StackPanel>
                            <TextBlock Text="CRAFTING" Style="{StaticResource Eyebrow}"/>
                            <TextBlock Text="Blueprint Library" Style="{StaticResource PageTitle}"/>
                            <TextBlock Text="Browse components and track which blueprints you own." Style="{StaticResource PageSubtitle}"/>
                        </StackPanel>
                        <ContentControl x:Name="BlueprintGlyphHost" HorizontalAlignment="Right" VerticalAlignment="Center" IsHitTestVisible="False"/>
                    </Grid>

                    <!-- Search bar with autocomplete -->
                    <Grid Grid.Row="1" Margin="20,6,20,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid Grid.Column="0">
                            <TextBox x:Name="BlueprintSearchBox"
                                     Style="{StaticResource NexusTextBox}" Height="44"
                                     Text="{Binding BlueprintSearch, UpdateSourceTrigger=PropertyChanged}"
                                     KeyDown="BlueprintSearch_KeyDown"
                                     TextChanged="BlueprintSearch_TextChanged"
                                     Tag="Search blueprints…"/>
                            <Popup x:Name="BlueprintSuggestPopup"
                                   PlacementTarget="{Binding ElementName=BlueprintSearchBox}"
                                   Placement="Bottom"
                                   Width="{Binding ActualWidth, ElementName=BlueprintSearchBox}"
                                   StaysOpen="False"
                                   AllowsTransparency="True">
                                <Border Background="{StaticResource Bg2NavBrush}"
                                        BorderBrush="{StaticResource NavBorderBrush}"
                                        BorderThickness="1" CornerRadius="0,0,4,4">
                                    <ListBox x:Name="BlueprintSuggestList"
                                             Background="Transparent" BorderThickness="0"
                                             MaxHeight="220"
                                             MouseLeftButtonUp="BlueprintSuggest_Click">
                                        <ListBox.ItemContainerStyle>
                                            <Style TargetType="ListBoxItem">
                                                <Setter Property="Foreground"        Value="{StaticResource FgBrush}"/>
                                                <Setter Property="Background"        Value="Transparent"/>
                                                <Setter Property="Padding"           Value="10,6"/>
                                                <Setter Property="FontFamily"        Value="{StaticResource UiFont}"/>
                                                <Setter Property="FontSize"          Value="13"/>
                                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="{StaticResource HighlightBrush}"/>
                                                    </Trigger>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter Property="Background" Value="{StaticResource AccentDimBrush}"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ListBox.ItemContainerStyle>
                                    </ListBox>
                                </Border>
                            </Popup>
                        </Grid>
                        <Button x:Name="BlueprintSearchClear" Grid.Column="1" Content="✕"
                                Style="{StaticResource NexusButton}"
                                Height="44" Width="44" Margin="6,0,0,0"
                                Visibility="Collapsed" ToolTip="Clear search"
                                Click="BlueprintSearchClear_Click"/>
                        <Button Grid.Column="2" Content="SEARCH"
                                Style="{StaticResource AccentButton}"
                                Margin="8,0,0,0" Height="44" Padding="20,0" FontSize="12"
                                Click="BlueprintSearchRun_Click"/>
                    </Grid>

                    <!-- Ownership filter chips + owned count (left); import-from-logs action (right) -->
                    <Grid Grid.Row="2" Margin="20,2,20,10">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left"
                                    VerticalAlignment="Center">
                            <Border x:Name="BpChipAll" CornerRadius="4" BorderThickness="1"
                                    Padding="12,4" Margin="0,0,6,0" Cursor="Hand"
                                    MouseLeftButtonDown="BpChipAll_Click">
                                <TextBlock x:Name="BpChipAllText" Text="All" FontSize="11"/>
                            </Border>
                            <Border x:Name="BpChipOwned" CornerRadius="4" BorderThickness="1"
                                    Padding="12,4" Margin="0,0,6,0" Cursor="Hand"
                                    MouseLeftButtonDown="BpChipOwned_Click">
                                <TextBlock x:Name="BpChipOwnedText" Text="Owned" FontSize="11"/>
                            </Border>
                            <Border x:Name="BpChipNotOwned" CornerRadius="4" BorderThickness="1"
                                    Padding="12,4" Margin="0,0,6,0" Cursor="Hand"
                                    MouseLeftButtonDown="BpChipNotOwned_Click">
                                <TextBlock x:Name="BpChipNotOwnedText" Text="Not owned" FontSize="11"/>
                            </Border>
                            <TextBlock x:Name="BpOwnedCount" Margin="6,0,0,0"
                                       VerticalAlignment="Center" FontSize="12"
                                       Foreground="{StaticResource CyanBrush}"/>
                        </StackPanel>
                        <Button x:Name="BpImportBtn" HorizontalAlignment="Right" VerticalAlignment="Center"
                                Content="Import owned from logs…" Style="{StaticResource NexusButton}"
                                Height="28" Padding="14,0" FontSize="11"
                                Click="BlueprintImportFromLogs_Click"
                                ToolTip="Scan your Star Citizen Game.log and logbackups for blueprints you've already received, and mark them owned"/>
                    </Grid>

                    <!-- Two-panel: left drill-down nav / right detail -->
                    <Grid Grid.Row="3" Margin="20,0,20,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="300"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Left: drill-down navigation (Category → Subcategory → blueprint) -->
                        <Border BorderBrush="{StaticResource NavBorderBrush}" BorderThickness="0,0,1,0">
                            <Grid Margin="0,4,12,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <!-- Sticky breadcrumb: stays pinned while the list below scrolls -->
                                <ContentControl x:Name="BlueprintCrumbHost" Grid.Row="0"/>
                                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                    <StackPanel x:Name="BlueprintNavPanel"/>
                                </ScrollViewer>
                            </Grid>
                        </Border>

                        <!-- Right: ingredient detail panel -->
                        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto"
                                      Margin="16,0,0,0">
                            <StackPanel x:Name="BlueprintDetailPanel"/>
                        </ScrollViewer>
                    </Grid>
                </Grid>

                <!-- ── MINING CODEX PAGE ── -->
                <Grid x:Name="PageReference" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <Grid Grid.Row="0" Margin="20,16,20,10">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="MINING" Style="{StaticResource Eyebrow}"/>
                            <TextBlock Text="Mining Codex" Style="{StaticResource PageTitle}"/>
                            <TextBlock Text="Resource properties, RS values, and refinery yields." Style="{StaticResource PageSubtitle}"/>
                        </StackPanel>
                        <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                            <ContentControl x:Name="ReferenceGlyphHost" VerticalAlignment="Center" Margin="0,0,14,0" IsHitTestVisible="False"/>
                            <Button x:Name="KeyButton" Content="Key  ▾" Style="{StaticResource NexusButton}"
                                    Height="28" Padding="12,0" FontSize="11" FontWeight="Bold"
                                    Foreground="{StaticResource GoldBrush}" BorderBrush="{StaticResource GoldBrush}"
                                    Margin="0,0,8,0" Click="KeyButton_Click"/>
                            <Button Content="Reset filters" Style="{StaticResource NexusButton}"
                                    Height="28" Padding="12,0" FontSize="11"
                                    Click="ResetSort_Click"/>
                        </StackPanel>

                        <!-- Color key popover (Rarity + Refinery) -->
                        <Popup x:Name="KeyPopup" PlacementTarget="{Binding ElementName=KeyButton}"
                               Placement="Bottom" StaysOpen="False" AllowsTransparency="True"
                               HorizontalOffset="-180" VerticalOffset="6">
                            <Border Background="{StaticResource Bg2NavBrush}"
                                    BorderBrush="{StaticResource GoldBrush}" BorderThickness="1"
                                    CornerRadius="4" Padding="20,16,24,18">
                                <Border.Effect>
                                    <DropShadowEffect Color="#000000" BlurRadius="18" ShadowDepth="3" Opacity="0.55"/>
                                </Border.Effect>
                                <StackPanel>
                                    <TextBlock Text="RARITY" FontSize="10" FontWeight="Bold"
                                               Foreground="{StaticResource GoldBrush}" Margin="0,0,0,8"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                        <Rectangle Width="11" Height="11" RadiusX="2" RadiusY="2" Fill="#FFD700" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        <TextBlock Text="Legendary" FontSize="11" Foreground="{StaticResource FgBrush}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                        <Rectangle Width="11" Height="11" RadiusX="2" RadiusY="2" Fill="#A855F7" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        <TextBlock Text="Epic" FontSize="11" Foreground="{StaticResource FgBrush}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                        <Rectangle Width="11" Height="11" RadiusX="2" RadiusY="2" Fill="#3B82F6" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        <TextBlock Text="Rare" FontSize="11" Foreground="{StaticResource FgBrush}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                        <Rectangle Width="11" Height="11" RadiusX="2" RadiusY="2" Fill="#22C55E" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        <TextBlock Text="Uncommon" FontSize="11" Foreground="{StaticResource FgBrush}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                        <Rectangle Width="11" Height="11" RadiusX="2" RadiusY="2" Fill="#9E9E9E" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        <TextBlock Text="Common" FontSize="11" Foreground="{StaticResource FgBrush}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <TextBlock Text="REFINERY YIELD" FontSize="10" FontWeight="Bold"
                                               Foreground="{StaticResource GoldBrush}" Margin="0,0,0,8"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                        <Rectangle Width="11" Height="11" RadiusX="2" RadiusY="2" Fill="#22C55E" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        <TextBlock Text="Bonus yield" FontSize="11" Foreground="{StaticResource FgBrush}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                        <Rectangle Width="11" Height="11" RadiusX="2" RadiusY="2" Fill="#8B949E" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        <TextBlock Text="No modifier" FontSize="11" Foreground="{StaticResource FgBrush}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <Rectangle Width="11" Height="11" RadiusX="2" RadiusY="2" Fill="#EF4444" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        <TextBlock Text="Reduced yield" FontSize="11" Foreground="{StaticResource FgBrush}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </Popup>
                    </Grid>

                    <!-- Search bar with clear button -->
                    <Grid Grid.Row="1" Margin="20,0,20,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Style="{StaticResource NexusTextBox}" Height="44"
                                 Text="{Binding RefFilter, UpdateSourceTrigger=PropertyChanged}"
                                 KeyDown="RefSearch_KeyDown"
                                 KeyUp="RefSearch_KeyUp"
                                 Tag="Search by resource, location, or blueprint…"/>
                        <Button Grid.Column="1" Content="✕" Style="{StaticResource NexusButton}"
                                Height="44" Width="44" Margin="6,0,0,0"
                                Click="RefClear_Click"/>
                    </Grid>

                    <!-- System filter -->
                    <StackPanel Grid.Row="2" Orientation="Horizontal"
                                Margin="20,0,20,4" VerticalAlignment="Center">
                        <TextBlock Text="System:" FontSize="11"
                                   Foreground="{StaticResource FgDimBrush}"
                                   VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <StackPanel x:Name="SystemFilterPanel" Orientation="Horizontal"/>
                    </StackPanel>

                    <!-- Method filter -->
                    <StackPanel Grid.Row="3" Orientation="Horizontal"
                                Margin="20,0,20,6" VerticalAlignment="Center">
                        <TextBlock Text="Method:" FontSize="11"
                                   Foreground="{StaticResource FgDimBrush}"
                                   VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <StackPanel x:Name="MethodFilterPanel" Orientation="Horizontal"/>
                    </StackPanel>

                    <Border Grid.Row="5" Height="1"
                            Background="{StaticResource NavBorderBrush}"
                            Margin="20,0,20,0"/>

                    <!-- two-panel: resource list | rich detail -->
                    <Grid Grid.Row="7" Margin="20,4,20,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="320"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" BorderBrush="{StaticResource NavBorderBrush}" BorderThickness="0,0,1,0">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel x:Name="ReferenceList"/>
                            </ScrollViewer>
                        </Border>
                        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto" Margin="16,0,0,0">
                            <StackPanel x:Name="ReferenceDetailPanel"/>
                        </ScrollViewer>
                    </Grid>
                </Grid>

                <!-- ── REFINERY TRACKER PAGE (card gallery; add/edit via popup) ── -->
                <Grid x:Name="PageWorkOrders" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Header: eyebrow + title + subtitle, ambient scan glyph + Add button -->
                    <Grid Grid.Row="0" Margin="20,16,20,8">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="CRAFTING" Style="{StaticResource Eyebrow}"/>
                            <TextBlock Text="Refinery" Style="{StaticResource PageTitle}"/>
                            <TextBlock Text="Work orders and refining timers across the verse."
                                       FontFamily="{StaticResource UiFont}" FontSize="12.5"
                                       Foreground="{StaticResource FgDimBrush}" Margin="0,4,0,0"/>
                        </StackPanel>
                        <StackPanel HorizontalAlignment="Right" VerticalAlignment="Center" Orientation="Horizontal">
                            <ContentControl x:Name="WorkOrderGlyphHost" VerticalAlignment="Center" Margin="0,0,14,0" IsHitTestVisible="False"/>
                            <Button x:Name="WoNewBtn" Content="+ Add work order"
                                    Style="{StaticResource AccentButton}"
                                    Height="34" Padding="16,0" Click="NewWorkOrder_Click"/>
                        </StackPanel>
                    </Grid>

                    <!-- Gallery: 2-up self-contained work-order cards (built in code) -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="13,4,13,16">
                        <StackPanel x:Name="WorkOrderGallery"/>
                    </ScrollViewer>
                </Grid>

                </Grid>
                </Grid>
                </views:ChamferPanel>
            </Grid>
        </Grid>

        <!-- ── MOBIGLAS HUD overlay: faint cyan scanlines + edge vignette.
             Non-interactive (IsHitTestVisible=False) so it never blocks input;
             sits above everything to give the projected-hardlight texture. ── -->
        <Grid Grid.Row="0" Grid.RowSpan="2" IsHitTestVisible="False" Panel.ZIndex="100">
            <Rectangle>
                <Rectangle.Fill>
                    <DrawingBrush TileMode="Tile" Viewport="0,0,3,3" ViewportUnits="Absolute" Stretch="None">
                        <DrawingBrush.Drawing>
                            <GeometryDrawing Brush="#0C7FE9E0">
                                <GeometryDrawing.Geometry>
                                    <RectangleGeometry Rect="0,0,3,1"/>
                                </GeometryDrawing.Geometry>
                            </GeometryDrawing>
                        </DrawingBrush.Drawing>
                    </DrawingBrush>
                </Rectangle.Fill>
            </Rectangle>
            <Border>
                <Border.Background>
                    <RadialGradientBrush GradientOrigin="0.5,0.42" Center="0.5,0.42" RadiusX="0.85" RadiusY="0.85">
                        <GradientStop Color="#00000000" Offset="0.5"/>
                        <GradientStop Color="#5C03060B" Offset="1.0"/>
                    </RadialGradientBrush>
                </Border.Background>
            </Border>
        </Grid>
    </Grid>
</Window>
