<Window x:Class="NexusApp.Views.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:NexusApp.Converters"
        xmlns:views="clr-namespace:NexusApp.Views"
        Title="Nexus Overlay"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent"
        FontFamily="{StaticResource UiFont}"
        Topmost="True"
        ResizeMode="CanResizeWithGrip"
        Width="320" Height="480"
        ShowInTaskbar="False">

    <Window.Resources>
        <conv:TierColorConverter x:Key="TierColor"/>
        <conv:RarityColorConverter x:Key="RarityColor"/>
        <conv:HexColorConverter x:Key="HexColor"/>
        <conv:BoolToVisibilityConverter x:Key="BoolVis"/>

        <!-- compact gold slider (visual only) -->
        <Style x:Key="OverlaySlider" TargetType="Slider">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid VerticalAlignment="Center">
                            <Border Height="3" CornerRadius="2"
                                    Background="{DynamicResource BorderBrush}" VerticalAlignment="Center"/>
                            <Track x:Name="PART_Track" Orientation="Horizontal">
                                <Track.Thumb>
                                    <Thumb Width="13" Height="13">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Ellipse Fill="{DynamicResource AccentBrush}"
                                                         Stroke="{DynamicResource OnAccentBrush}" StrokeThickness="1"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- ── Floating HUD panel: MOBIGLAS chamfered shell (TL + BR bevel, like the mock's clip-path).
         FramePath draws the bevelled fill + 1px slate border; ContentRoot is clipped to the same
         silhouette so inner content can't poke past the bevel. Both geometries recompute on resize
         in code-behind (UpdateChamfer). ── -->
    <Grid>
        <Path x:Name="FramePath" StrokeThickness="1" SnapsToDevicePixels="True"
              Stroke="{DynamicResource BorderBrush}">
            <Path.Fill>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="{DynamicResource OverlayBgTopColor}" Offset="0"/>
                    <GradientStop Color="{DynamicResource OverlayBgBotColor}" Offset="1"/>
                </LinearGradientBrush>
            </Path.Fill>
        </Path>
        <Grid x:Name="ContentRoot">
            <Grid.RowDefinitions>
                <RowDefinition Height="34"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition x:Name="HistorySplitterRow" Height="4" MinHeight="4"/>
                <RowDefinition x:Name="HistoryStripRow" Height="120" MinHeight="50"/>
            </Grid.RowDefinitions>

            <!-- ── Header: drag zone + opacity + close ── -->
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0,0,0"
                            HorizontalAlignment="Stretch" Background="Transparent"
                            MouseLeftButtonDown="Header_MouseLeftButtonDown" Cursor="SizeAll">
                    <!-- Animated Nexus mark (beam + sparks), replacing the old spinning arc. -->
                    <views:NexusBeamIcon Width="18" Height="18" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock Text="NEXUS" Foreground="{DynamicResource AccentBrush}"
                               FontFamily="{StaticResource DisplayFont}" FontWeight="Bold"
                               FontSize="16" VerticalAlignment="Center"/>
                    <TextBlock Text="OVERLAY" Foreground="{DynamicResource FgDimBrush}"
                               FontFamily="{StaticResource UiFont}"
                               FontSize="8" FontWeight="Bold" VerticalAlignment="Center"
                               Margin="7,3,0,0"/>
                </StackPanel>
                <!-- Window opacity - shared across every tab -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,6,0">
                    <Slider x:Name="OpacitySlider" Style="{StaticResource OverlaySlider}"
                            Minimum="0.2" Maximum="1.0" SmallChange="0.05"
                            Width="74" VerticalAlignment="Center" Margin="0,0,6,0"
                            ToolTip="Overlay opacity"
                            ValueChanged="OpacitySlider_ValueChanged"/>
                    <TextBlock x:Name="OpacityLabel" Text="100%"
                               FontFamily="{StaticResource MonoFont}"
                               FontSize="9" Foreground="{DynamicResource FgDimBrush}"
                               VerticalAlignment="Center" Width="30"/>
                </StackPanel>
                <Button Grid.Column="2" Content="✕" Style="{StaticResource NexusButton}"
                        Width="26" Height="26" Padding="0" VerticalAlignment="Center"
                        Margin="0,0,8,0" Click="Close_Click"/>
                <!-- accent hairline under header -->
                <Border Grid.ColumnSpan="3" VerticalAlignment="Bottom" Height="1" Margin="12,0,12,0">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="{DynamicResource AccentClearColor}" Offset="0"/>
                            <GradientStop Color="{DynamicResource AccentGlowColor}" Offset="0.5"/>
                            <GradientStop Color="{DynamicResource AccentClearColor}" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                </Border>
            </Grid>

            <!-- ── Tab bar ── -->
            <Grid Grid.Row="1" Margin="0,2,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <Button x:Name="TabStatsBtn" Content="HUB"
                            Style="{StaticResource NexusButton}" FontSize="9" FontWeight="Bold"
                            Background="Transparent" BorderThickness="0"
                            Click="TabStats_Click" Padding="0,5" Margin="0"/>
                    <Border x:Name="TabStatsIndicator" Height="2" Width="34"
                            CornerRadius="1" Background="Transparent"/>
                </StackPanel>
                <StackPanel Grid.Column="1">
                    <Button x:Name="TabScanBtn" Content="SCAN"
                            Style="{StaticResource NexusButton}" FontSize="9" FontWeight="Bold"
                            Background="Transparent" BorderThickness="0"
                            Click="TabScan_Click" Padding="0,5" Margin="0"/>
                    <Border x:Name="TabScanIndicator" Height="2" Width="34"
                            CornerRadius="1" Background="{DynamicResource AccentBrush}"/>
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <Button x:Name="TabOrdersBtn" Content="REFINERY"
                            Style="{StaticResource NexusButton}" FontSize="9" FontWeight="Bold"
                            Background="Transparent" BorderThickness="0"
                            Click="TabOrders_Click" Padding="0,5" Margin="0"/>
                    <Border x:Name="TabOrdersIndicator" Height="2" Width="54"
                            CornerRadius="1" Background="Transparent"/>
                </StackPanel>
                <StackPanel Grid.Column="3">
                    <Button x:Name="TabShoppingBtn" Content="SHOPPING"
                            Style="{StaticResource NexusButton}" FontSize="9" FontWeight="Bold"
                            Background="Transparent" BorderThickness="0"
                            Click="TabShopping_Click" Padding="0,5" Margin="0"/>
                    <Border x:Name="TabShoppingIndicator" Height="2" Width="54"
                            CornerRadius="1" Background="Transparent"/>
                </StackPanel>
                <StackPanel Grid.Column="4">
                    <Button x:Name="TabHaulingBtn" Content="HAULING"
                            Style="{StaticResource NexusButton}" FontSize="9" FontWeight="Bold"
                            Background="Transparent" BorderThickness="0"
                            Click="TabHauling_Click" Padding="0,5" Margin="0"/>
                    <Border x:Name="TabHaulingIndicator" Height="2" Width="48"
                            CornerRadius="1" Background="Transparent"/>
                </StackPanel>
                <Border Grid.ColumnSpan="5" VerticalAlignment="Bottom" Height="1"
                        Background="{DynamicResource NavBorderBrush}"/>
            </Grid>

            <!-- ── Tab content ── -->
            <Grid Grid.Row="2">

                <!-- HUB tab (Beta Game.log session): MOBIGLAS glance. Mock order = SCAN STATUS LEDs,
                     BLUEPRINTS COLLECTED hero (accent chamfer + count-up), SERVER / SHARD (chamfer),
                     COLLECTION LOG. One vertical scroll, like the mock's .body. The pills / status line /
                     footer the old layout carried are gone: session-monitoring shows via the LEDs, and
                     Reset session / advanced monitor now live in the advanced Game.log monitor. -->
                <ScrollViewer x:Name="StatsTabContent" Visibility="Collapsed"
                              VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="12,10,12,12">

                        <!-- SCAN STATUS: read-only LED pills (green on / yellow paused / red off),
                             synced from the SCAN + HAULING toggles (built in BuildHubScanControls). -->
                        <TextBlock Text="SCAN STATUS" Style="{StaticResource SectionLabel}" Margin="1,0,0,6"/>
                        <WrapPanel x:Name="HubScanBar"/>

                        <!-- BLUEPRINTS COLLECTED hero: big cyan count-up for this session (CountUp.SetTo). -->
                        <views:ChamferPanel Accent="True" ShowBrackets="True" Chamfer="12"
                                            Padding="13,11" Margin="0,11,0,0">
                            <StackPanel>
                                <TextBlock Text="BLUEPRINTS COLLECTED" Style="{StaticResource SectionLabel}"/>
                                <Border Height="1" Background="{DynamicResource NavBorderBrush}" Margin="0,6,0,8"/>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock x:Name="StatsBigCount" Text="0"
                                               FontFamily="{StaticResource MonoFont}" FontSize="40" FontWeight="Bold"
                                               Foreground="{DynamicResource CyanBrush}" VerticalAlignment="Bottom">
                                        <TextBlock.Effect>
                                            <DropShadowEffect Color="{DynamicResource CyanColor}" BlurRadius="16"
                                                              ShadowDepth="0" Opacity="0.4"/>
                                        </TextBlock.Effect>
                                    </TextBlock>
                                    <TextBlock Text="this session" FontFamily="{StaticResource MonoFont}" FontSize="11"
                                               Foreground="{DynamicResource FgDimBrush}"
                                               Margin="9,0,0,7" VerticalAlignment="Bottom"/>
                                </StackPanel>
                            </StackPanel>
                        </views:ChamferPanel>

                        <!-- SERVER / SHARD: current + recent shards (built in code-behind, RebuildShardPanel). -->
                        <views:ChamferPanel Chamfer="12" Padding="13,10" Margin="0,11,0,0">
                            <StackPanel x:Name="ShardPanel"/>
                        </views:ChamferPanel>

                        <!-- COLLECTION LOG: blueprint feed (newest first), inline in the scroll. -->
                        <TextBlock Text="COLLECTION LOG" Style="{StaticResource Eyebrow}" Margin="1,13,0,4"/>
                        <Grid MinHeight="56">
                            <StackPanel x:Name="StatsFeedItems"/>
                            <TextBlock x:Name="StatsEmptyState"
                                       Text="No blueprints yet this session.&#x0a;Unlock one in-game and it appears here."
                                       FontSize="10" Foreground="{DynamicResource FgDimBrush}"
                                       TextAlignment="Center" TextWrapping="Wrap"
                                       VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>

                <!-- SCAN tab -->
                <Grid x:Name="ScanTabContent">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Scan controls: Auto-scan / Scan box toggle switches (built in code-behind to
                         match the STATS tab) + a Set RS detection region link. -->
                    <StackPanel Grid.Row="0" Margin="10,10,10,2">
                        <WrapPanel x:Name="ScanControlBar"/>
                        <TextBlock x:Name="SetRegionBtn" Text="⊕  Set RS detection region" FontSize="11"
                                   Foreground="{DynamicResource AccentBrush}" Cursor="Hand"
                                   Background="Transparent" Padding="2,3,2,2"
                                   HorizontalAlignment="Left" MouseLeftButtonUp="SetRegion_Click"/>
                    </StackPanel>

                    <!-- Scan status chip (chamfered) -->
                    <views:ChamferPanel Grid.Row="1" HorizontalAlignment="Left" Margin="10,8,10,0"
                                        Chamfer="7" Padding="10,3">
                        <TextBlock x:Name="OverlayScanStatus"
                                   Text="◎  Scan off" FontSize="10"
                                   Foreground="{DynamicResource FgDimBrush}"
                                   TextTrimming="CharacterEllipsis"/>
                    </views:ChamferPanel>

                    <!-- RS input -->
                    <Grid Grid.Row="2" Margin="10,8,10,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="OverlayRsInput" Style="{StaticResource ChamferTextBox}"
                                 Height="42" FontSize="16" FontFamily="{StaticResource MonoFont}"
                                 KeyDown="OverlayRsInput_KeyDown"
                                 Tag="Enter RS value…"/>
                        <Button Grid.Column="1" Content="→" Style="{StaticResource ChamferAccentButton}"
                                Height="42" Margin="6,0,0,0" Padding="13,0" FontSize="16"
                                Click="OverlayScan_Click"/>
                    </Grid>

                    <!-- Results -->
                    <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto" Margin="10,0">
                        <ItemsControl x:Name="OverlayResults">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <views:ChamferPanel Margin="0,3" Chamfer="9" ClipContent="True" Padding="0">
                                        <views:ChamferPanel.Style>
                                            <Style TargetType="{x:Type views:ChamferPanel}" BasedOn="{StaticResource {x:Type views:ChamferPanel}}">
                                                <Setter Property="Background"    Value="{DynamicResource Bg3Brush}"/>
                                                <Setter Property="BorderBrush"   Value="{DynamicResource BorderBrush}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsInCart}" Value="True">
                                                        <Setter Property="Background"  Value="{DynamicResource AccentTintBrush}"/>
                                                        <Setter Property="BorderBrush" Value="{DynamicResource AccentStrongBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </views:ChamferPanel.Style>
                                        <Grid>
                                            <Border Width="3" HorizontalAlignment="Left"
                                                    Background="{Binding CardColor, Converter={StaticResource HexColor}}"/>
                                            <Grid Margin="11,8">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel>
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="{Binding Resource.Name}" FontWeight="SemiBold"
                                                                   Foreground="{Binding Resource.Rarity, Converter={StaticResource RarityColor}}"
                                                                   VerticalAlignment="Center"/>
                                                        <Border Padding="3,1" CornerRadius="3" Margin="5,0,0,0"
                                                                Background="{DynamicResource AccentBrush}"
                                                                VerticalAlignment="Center"
                                                                Visibility="{Binding IsInCart, Converter={StaticResource BoolVis}}">
                                                            <TextBlock Text="CART" FontSize="8" FontWeight="Bold"
                                                                       Foreground="{DynamicResource OnAccentBrush}"/>
                                                        </Border>
                                                    </StackPanel>
                                                    <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                                                        <Border Padding="4,2" CornerRadius="3" Margin="0,0,6,0"
                                                                Background="{DynamicResource HighlightBrush}">
                                                            <TextBlock Text="{Binding BadgeText}" FontSize="10"
                                                                       FontWeight="Bold"
                                                                       Foreground="{Binding CardColor, Converter={StaticResource HexColor}}"/>
                                                        </Border>
                                                        <TextBlock Text="{Binding Resource.BaseRs, StringFormat='RS {0:N0}'}"
                                                                   FontFamily="{StaticResource MonoFont}"
                                                                   FontSize="11" Foreground="{DynamicResource CyanBrush}"
                                                                   Margin="0,0,6,0" VerticalAlignment="Center"/>
                                                        <TextBlock Text="{Binding NodesText}"
                                                                   FontFamily="{StaticResource MonoFont}"
                                                                   FontSize="11" Foreground="{DynamicResource FgDimBrush}"
                                                                   VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </StackPanel>
                                            </Grid>
                                        </Grid>
                                    </views:ChamferPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>

                <!-- ORDERS tab -->
                <Grid x:Name="OrdersTabContent" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Button x:Name="WorkOrderBtn" Grid.Row="0" Content="▤   Open Refinery Tracker"
                            Style="{StaticResource ChamferAccentButton}"
                            HorizontalAlignment="Stretch"
                            Padding="0,12" Margin="10,12,10,0"
                            Click="WorkOrderToggle_Click"/>

                    <StackPanel x:Name="OrdersSummaryPanel" Grid.Row="1" Margin="10,14,10,0"/>

                    <Grid Grid.Row="2" Margin="0,8,0,0">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel x:Name="OrdersPanelItems" Margin="10,0"/>
                        </ScrollViewer>
                        <StackPanel x:Name="OrdersEmptyState" VerticalAlignment="Center"
                                    HorizontalAlignment="Center" Visibility="Collapsed">
                            <views:ChamferPanel Width="46" Height="46" Chamfer="6"
                                                Background="Transparent" BorderBrush="{DynamicResource BorderBrush}"
                                                Padding="0" HorizontalAlignment="Center">
                                <TextBlock Text="▤" FontSize="20" Foreground="{DynamicResource FgDimBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </views:ChamferPanel>
                            <TextBlock Text="No active work orders" FontSize="11" FontWeight="Bold"
                                       Foreground="{DynamicResource FgDimBrush}"
                                       HorizontalAlignment="Center" Margin="0,12,0,0"/>
                            <TextBlock Text="Open the tracker to create one" FontSize="9"
                                       Foreground="{DynamicResource FgDimBrush}"
                                       HorizontalAlignment="Center" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Grid>
                </Grid>

                <!-- SHOPPING tab -->
                <Grid x:Name="ShoppingTabContent" Visibility="Collapsed">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="8,6">
                        <StackPanel x:Name="ShoppingPanelItems"/>
                    </ScrollViewer>
                </Grid>

                <!-- HAULING tab: contract scan controls (fixed) + active hauls + consolidation glance (App.Hauls) -->
                <Grid x:Name="HaulingTabContent" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Contract scan controls: Auto-scan contracts / Contract box toggle switches (built in
                         code-behind to match the SCAN tab) + a Set contract detection region link. Fixed area, OUTSIDE
                         HaulingList (which RebuildHaulingPanel clears). -->
                    <StackPanel Grid.Row="0" Margin="10,10,10,2">
                        <WrapPanel x:Name="HaulingControlBar"/>
                        <TextBlock x:Name="SetContractRegionBtn" Text="⊕  Set contract detection region" FontSize="11"
                                   Foreground="{DynamicResource AccentBrush}" Cursor="Hand"
                                   Background="Transparent" Padding="2,3,2,2"
                                   HorizontalAlignment="Left" MouseLeftButtonUp="SetContractRegion_Click"/>
                    </StackPanel>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="10,8">
                        <StackPanel x:Name="HaulingList"/>
                    </ScrollViewer>
                </Grid>
            </Grid>

            <!-- Drag handle to resize history strip -->
            <GridSplitter x:Name="HistorySplitter" Grid.Row="3" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                          Background="{DynamicResource NavBorderBrush}" Cursor="SizeNS"
                          ResizeDirection="Rows" ResizeBehavior="PreviousAndNext"/>

            <!-- History strip (RECENT scans - hidden on the STATS tab; it's scan-only) -->
            <Border x:Name="HistoryStrip_Container" Grid.Row="4" Background="{DynamicResource NavBgBrush}">
                <DockPanel>
                    <Grid DockPanel.Dock="Top" Margin="12,6,8,4">
                        <TextBlock Text="RECENT" Style="{StaticResource SectionLabel}"
                                   VerticalAlignment="Center"/>
                        <Button Content="CLEAR" Style="{StaticResource NexusButton}"
                                HorizontalAlignment="Right"
                                Padding="6,2" FontSize="9"
                                Click="ClearHistory_Click"/>
                    </Grid>
                    <StackPanel x:Name="OverlayHistoryFilterPanel" DockPanel.Dock="Top"
                                Orientation="Horizontal" Margin="12,0,8,4"/>
                    <Border DockPanel.Dock="Top" Height="1" Background="{DynamicResource NavBorderBrush}"/>
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  Padding="6,4,6,4">
                        <StackPanel x:Name="HistoryStrip"/>
                    </ScrollViewer>
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
