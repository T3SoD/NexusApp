<Window x:Class="Nexus_v4.Views.RegionSelectorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Select Scan Region"
        WindowStyle="None" AllowsTransparency="True"
        Background="#88000000"
        Topmost="True" ShowInTaskbar="False"
        WindowState="Maximized"
        Cursor="Cross">

    <Grid>
        <!-- Instructions -->
        <TextBlock HorizontalAlignment="Center" VerticalAlignment="Top"
                   Margin="0,32,0,0" FontSize="16" Foreground="White"
                   Text="Click and drag to select the RS value region. Press Escape to cancel."/>

        <!-- Canvas must have Background set (even Transparent) for WPF hit-testing to work.
             HorizontalAlignment/VerticalAlignment=Stretch makes it fill the Grid cell. -->
        <Canvas x:Name="DrawCanvas"
                Background="Transparent"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                MouseLeftButtonDown="Canvas_MouseDown"
                MouseMove="Canvas_MouseMove"
                MouseLeftButtonUp="Canvas_MouseUp">
            <Rectangle x:Name="SelectRect"
                       Stroke="#FFFF00FF" StrokeThickness="3"
                       Fill="Transparent"
                       Visibility="Collapsed"/>
        </Canvas>
    </Grid>
</Window>
