<Window x:Class="Nexus_v4.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Nexus_v4.ViewModels"
        xmlns:conv="clr-namespace:Nexus_v4.Converters"
        xmlns:models="clr-namespace:Nexus_v4.Models"
        Title="Nexus" Icon="/Assets/nexus_icon.png" Height="820" Width="1280"
        MinHeight="600" MinWidth="900"
        Background="{DynamicResource BgBrush}"
        Foreground="{DynamicResource FgBrush}"
        FontFamily="{StaticResource UiFont}"
        WindowStyle="SingleBorderWindow" AllowsTransparency="False"
        ResizeMode="CanResize">

    <Window.Resources>
        <conv:TierColorConverter             x:Key="TierColor"/>
        <conv:RarityColorConverter           x:Key="RarityColor"/>
        <conv:SystemColorConverter           x:Key="SystemColor"/>
        <conv:RefineryModifierColorConverter x:Key="ModColor"/>
        <conv:BoolToVisibilityConverter      x:Key="BoolVis"/>
        <conv:HexColorConverter              x:Key="HexColor"/>
        <conv:WorkOrderStatusColorConverter  x:Key="WoStatusColor"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="68"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ── Header strip (68px) — caption area for WindowChrome drag ── -->
        <Grid Grid.Row="0"
              Background="{DynamicResource NavBgBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Left: logo + title + version badges -->
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0,0,0">
                <Image Source="/Assets/nexus_icon.png" Width="28" Height="28"
                       Stretch="Uniform" Margin="0,0,8,0" VerticalAlignment="Center"/>
                <TextBlock Text="Nexus" FontSize="14" FontWeight="Bold"
                           Foreground="{StaticResource FgBrush}" Margin="0,0,10,0"
                           VerticalAlignment="Center"/>
                <Border Padding="6,3" CornerRadius="4" Margin="0,0,6,0"
                        Background="{StaticResource Bg2NavBrush}"
                        BorderBrush="{StaticResource NavBorderBrush}"
                        BorderThickness="1">
                    <TextBlock x:Name="GameVersionText" FontSize="9"
                               Foreground="{StaticResource GoldBrush}"
                               VerticalAlignment="Center"/>
                </Border>
                <!-- App version badge — clickable easter egg -->
                <Border x:Name="AppVersionBadge"
                        Padding="6,3" CornerRadius="4" Margin="0,0,6,0"
                        Background="Transparent"
                        BorderBrush="{StaticResource AccentDimBrush}"
                        BorderThickness="1"
                        Cursor="Hand"
                        MouseLeftButtonDown="AppBadge_Click">
                    <TextBlock x:Name="AppVersionText" FontSize="9"
                               Foreground="{StaticResource AccentBrush}"
                               FontWeight="Bold"
                               VerticalAlignment="Center"/>
                </Border>
                <!-- Easter egg hint — hidden until badge is clicked -->
                <TextBlock x:Name="EggHintLabel"
                           Text="" FontSize="9" FontStyle="Italic"
                           Foreground="{StaticResource FgDimBrush}"
                           VerticalAlignment="Center" Margin="0,0,8,0"
                           Visibility="Collapsed"/>
            </StackPanel>

            <!-- Right: action buttons -->
            <StackPanel Grid.Column="1" Orientation="Horizontal"
                        VerticalAlignment="Center" Margin="0,0,8,0">
                <Button x:Name="OverlayToggleBtn" Content="⧉" ToolTip="Toggle Overlay"
                        Style="{StaticResource HeaderButton}"
                        Width="38" Height="38" Margin="2,0"
                        Click="ToggleOverlay_Click"/>
                <Button Content="🛒" ToolTip="Shopping List"
                        Style="{StaticResource HeaderButton}"
                        Width="38" Height="38" Margin="2,0"
                        Click="ShowShopping_Click"/>
                <Button Content="?" ToolTip="Help"
                        Style="{StaticResource HeaderButton}"
                        Width="38" Height="38" Margin="2,0"
                        Click="Help_Click"/>
                <Button Content="ℹ" ToolTip="About"
                        Style="{StaticResource HeaderButton}"
                        Width="38" Height="38" Margin="2,0"
                        Click="About_Click"/>
            </StackPanel>
        </Grid>

        <!-- ── Data-update banner (hidden until an update is staged) ── -->
        <Border x:Name="DataUpdateBanner" Grid.Row="1" Visibility="Collapsed"
                Background="#1A00C9A7" BorderBrush="#5500C9A7" BorderThickness="0,0,0,1"
                Padding="16,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="DataUpdateText" VerticalAlignment="Center" FontSize="12"
                           TextWrapping="Wrap"
                           Foreground="{StaticResource FgBrush}"
                           Text="Updated mining data is available."/>
                <Button Grid.Column="1" Content="Restart now"
                        Style="{StaticResource AccentButton}" Padding="14,5"
                        Margin="12,0,0,0" Click="RestartForUpdate_Click"/>
                <Button Grid.Column="2" Content="✕"
                        Style="{StaticResource NexusButton}"
                        Width="26" Height="26" Padding="0" Margin="8,0,0,0"
                        VerticalAlignment="Center"
                        Click="DismissDataBanner_Click" ToolTip="Dismiss (the update still applies next launch)"/>
            </Grid>
        </Border>

        <!-- ── Body: sidebar + content ── -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="175"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ── Sidebar ── -->
            <Border Grid.Column="0"
                    Background="{DynamicResource NavBgBrush}"
                    BorderBrush="{DynamicResource NavBorderBrush}"
                    BorderThickness="0,0,1,0">
                <DockPanel>
                    <!-- Nav area (fills remaining space, top-aligned) -->
                    <StackPanel>
                        <!-- Logo area -->
                        <StackPanel HorizontalAlignment="Center" Margin="8,14,8,12">
                            <Image Source="/Assets/nexus_logo.png" MaxWidth="140"
                                   Stretch="Uniform" HorizontalAlignment="Center"/>
                        </StackPanel>
                        <!-- Divider + section label -->
                        <Border Height="1" Background="{StaticResource NavBorderBrush}"/>
                        <TextBlock Text="NAVIGATION" FontSize="9" FontWeight="Bold"
                                   Foreground="{StaticResource FgDimBrush}"
                                   Margin="14,10,14,6"/>

                        <!-- Nav items -->
                        <RadioButton x:Name="NavScan" Tag="scan" Style="{StaticResource NavButton}"
                                     IsChecked="True" Click="Nav_Click" MinHeight="52">
                            <RadioButton.Content>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="RS" FontSize="11" FontWeight="Bold" Width="26"
                                               VerticalAlignment="Center" Margin="0,0,4,0"/>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="RS SIGNAL" FontSize="11" FontWeight="Bold"/>
                                        <TextBlock Text="DECODER" FontSize="11" FontWeight="Bold"/>
                                    </StackPanel>
                                </StackPanel>
                            </RadioButton.Content>
                        </RadioButton>

                        <RadioButton x:Name="NavBlue" Tag="blueprints" Style="{StaticResource NavButton}"
                                     Click="Nav_Click" MinHeight="52">
                            <RadioButton.Content>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="▣" FontSize="16" Width="26"
                                               VerticalAlignment="Center" Margin="0,0,4,0"/>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="BLUEPRINT" FontSize="11" FontWeight="Bold"/>
                                        <TextBlock Text="LIBRARY" FontSize="11" FontWeight="Bold"/>
                                    </StackPanel>
                                </StackPanel>
                            </RadioButton.Content>
                        </RadioButton>

                        <RadioButton x:Name="NavRef" Tag="reference" Style="{StaticResource NavButton}"
                                     Click="Nav_Click" MinHeight="52">
                            <RadioButton.Content>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="◆" FontSize="16" Width="26"
                                               VerticalAlignment="Center" Margin="0,0,4,0"/>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="MINING" FontSize="11" FontWeight="Bold"/>
                                        <TextBlock Text="CODEX" FontSize="11" FontWeight="Bold"/>
                                    </StackPanel>
                                </StackPanel>
                            </RadioButton.Content>
                        </RadioButton>

                        <RadioButton x:Name="NavWork" Tag="workorders" Style="{StaticResource NavButton}"
                                     Click="Nav_Click" MinHeight="52">
                            <RadioButton.Content>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="◑" FontSize="16" Width="26"
                                               VerticalAlignment="Center" Margin="0,0,4,0"/>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="REFINERY" FontSize="11" FontWeight="Bold"/>
                                        <TextBlock Text="TRACKER" FontSize="11" FontWeight="Bold"/>
                                    </StackPanel>
                                </StackPanel>
                            </RadioButton.Content>
                        </RadioButton>
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- ── Page content ── -->
            <Grid Grid.Column="1" Background="{DynamicResource PageBgBrush}">

                <!-- ── RS SIGNAL DECODER PAGE ── -->
                <Grid x:Name="PageScan" Visibility="Visible">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Input row -->
                    <Grid Grid.Row="0" Margin="20,20,20,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="RsInputBox"
                                 Style="{StaticResource NexusTextBox}"
                                 FontSize="14" Height="44"
                                 Text="{Binding RsInput, UpdateSourceTrigger=PropertyChanged}"
                                 KeyDown="RsInput_KeyDown"
                                 Tag="Enter RS value…"
                                 ToolTip="Enter RS value and press Enter  ·  use ';' for multiple"/>
                        <Button Grid.Column="1" Content="SCAN"
                                Style="{StaticResource AccentButton}"
                                Height="44" Width="90" Margin="8,0,0,0"
                                FontSize="12"
                                Command="{Binding LookupCommand}"/>
                        <Button Grid.Column="2" Content="Clear"
                                Style="{StaticResource NexusButton}"
                                Height="44" Margin="6,0,0,0" Padding="14,0"
                                Command="{Binding ClearScanCommand}"/>
                    </Grid>

                    <!-- OCR status + match legend row -->
                    <StackPanel Grid.Row="1" Margin="20,8,20,4">
                        <TextBlock Text="{Binding StatusText}"
                                   FontSize="10"
                                   Foreground="{StaticResource FgDimBrush}"
                                   Margin="0,0,0,4"/>
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="8" Height="8" Fill="#FF3FB950" Margin="0,0,4,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Exact" FontSize="11" Foreground="{StaticResource FgDimBrush}" Margin="0,0,12,0"/>
                            <Ellipse Width="8" Height="8" Fill="#FFE3B341" Margin="0,0,4,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Close match (≤0.5%)" FontSize="11" Foreground="{StaticResource FgDimBrush}" Margin="0,0,12,0"/>
                            <TextBlock Text="RS values are patch-specific" FontSize="11" Foreground="{StaticResource FgDimBrush}"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Results cards -->
                    <ScrollViewer Grid.Row="2"
                                  VerticalScrollBarVisibility="Auto"
                                  Margin="20,4,20,0">
                        <ItemsControl ItemsSource="{Binding ScanResults}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <!-- Card matches Python: border-left color = match quality -->
                                    <Border Margin="0,3" CornerRadius="6" Cursor="Hand">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background"    Value="{StaticResource Bg2NavBrush}"/>
                                                <Setter Property="BorderBrush"   Value="{StaticResource NavBorderBrush}"/>
                                                <Setter Property="BorderThickness" Value="1"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsInCart}" Value="True">
                                                        <Setter Property="Background"  Value="#1A00C9A7"/>
                                                        <Setter Property="BorderBrush" Value="#9900C9A7"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Grid>
                                            <!-- Left color bar: green=exact, amber=close match -->
                                            <Border Width="4" HorizontalAlignment="Left"
                                                    CornerRadius="6,0,0,6"
                                                    Background="{Binding CardColor, Converter={StaticResource HexColor}}"/>
                                            <Grid Margin="16,10,14,10">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <!-- Left: name, badge, RS, nodes -->
                                                <StackPanel>
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock
                                                            Text="{Binding Resource.Name}"
                                                            FontSize="14" FontWeight="Bold"
                                                            Foreground="{Binding Resource.Rarity, Converter={StaticResource RarityColor}}"
                                                            VerticalAlignment="Center"/>
                                                        <Border Padding="5,2" CornerRadius="3" Margin="8,0,0,0"
                                                                Background="#FF00C9A7"
                                                                VerticalAlignment="Center"
                                                                Visibility="{Binding IsInCart, Converter={StaticResource BoolVis}}">
                                                            <TextBlock Text="IN CART" FontSize="9" FontWeight="Bold"
                                                                       Foreground="#FF070B12"/>
                                                        </Border>
                                                    </StackPanel>
                                                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                                        <!-- Badge: EXACT / ~X.XX% -->
                                                        <Border Padding="5,2" CornerRadius="3" Margin="0,0,8,0"
                                                                Background="{StaticResource Bg3Brush}">
                                                            <TextBlock Text="{Binding BadgeText}"
                                                                       FontSize="10" FontWeight="Bold"
                                                                       Foreground="{Binding CardColor, Converter={StaticResource HexColor}}"/>
                                                        </Border>
                                                        <TextBlock
                                                            Text="{Binding Resource.BaseRs, StringFormat='RS {0:N0}'}"
                                                            FontSize="11"
                                                            Foreground="{StaticResource FgDimBrush}"
                                                            Margin="0,0,8,0"
                                                            VerticalAlignment="Center"/>
                                                        <TextBlock
                                                            Text="{Binding NodesText}"
                                                            FontSize="11"
                                                            Foreground="{StaticResource FgDimBrush}"
                                                            VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </StackPanel>

                                                <!-- Right: shopping button -->
                                                <Button Grid.Column="1" Content="🛒"
                                                        Style="{StaticResource NexusButton}"
                                                        Padding="8,4"
                                                        VerticalAlignment="Center"
                                                        Command="{Binding DataContext.AddResourceToShoppingCommand,
                                                                  RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CommandParameter="{Binding Resource}"
                                                        ToolTip="Add to shopping list"/>
                                            </Grid>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <!-- Scan history -->
                    <Border x:Name="ScanHistorySection" Grid.Row="3" MaxHeight="168"
                            Background="{StaticResource Bg2NavBrush}"
                            BorderBrush="{StaticResource NavBorderBrush}"
                            BorderThickness="0,1,0,0">
                        <DockPanel>
                            <Grid DockPanel.Dock="Top" Margin="14,6,10,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="RECENT SCANS" FontSize="10" FontWeight="Bold"
                                           Foreground="{StaticResource FgDimBrush}"
                                           VerticalAlignment="Center"/>
                                <StackPanel Grid.Column="1" x:Name="HistoryFilterPanel"
                                            Orientation="Horizontal" HorizontalAlignment="Center"
                                            VerticalAlignment="Center" Margin="8,0"/>
                                <Button Grid.Column="2" Content="Clear"
                                        Style="{StaticResource NexusButton}"
                                        Height="20" Padding="6,0" FontSize="10"
                                        Command="{Binding ClearHistoryCommand}"/>
                            </Grid>
                            <Border DockPanel.Dock="Top" Height="1"
                                    Background="{StaticResource NavBorderBrush}"/>
                            <ScrollViewer VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled"
                                          Padding="8,6,8,6">
                                <ItemsControl ItemsSource="{Binding FilteredScanHistory}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button Margin="0" Cursor="Hand"
                                                    HorizontalContentAlignment="Stretch"
                                                    Click="HistoryItem_Click">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border x:Name="row" Padding="14,5,14,5"
                                                                Background="Transparent">
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                </Grid.ColumnDefinitions>
                                                                <TextBlock Grid.Column="0" Text="◆" FontSize="10"
                                                                           Foreground="{Binding RsColor, Converter={StaticResource HexColor}}"
                                                                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                                                    <TextBlock Text="{Binding TopResource}"
                                                                               FontSize="11"
                                                                               Foreground="{StaticResource FgBrush}"
                                                                               Opacity="{Binding NameOpacity}"
                                                                               VerticalAlignment="Center"
                                                                               TextTrimming="CharacterEllipsis"/>
                                                                    <Border Padding="4,1" CornerRadius="3" Margin="6,0,0,0"
                                                                                Background="#FF00C9A7"
                                                                                VerticalAlignment="Center"
                                                                                Visibility="{Binding IsInCart, Converter={StaticResource BoolVis}}">
                                                                        <TextBlock Text="CART" FontSize="8" FontWeight="Bold"
                                                                                   Foreground="#FF070B12"/>
                                                                    </Border>
                                                                </StackPanel>
                                                                <TextBlock Grid.Column="2"
                                                                           Text="{Binding Rs, StringFormat='RS {0:N0}'}"
                                                                           FontSize="11"
                                                                           Foreground="{Binding RsColor, Converter={StaticResource HexColor}}"
                                                                           VerticalAlignment="Center"/>
                                                            </Grid>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <DataTrigger Binding="{Binding IsInCart}" Value="True">
                                                                <Setter TargetName="row" Property="Background" Value="#1A00C9A7"/>
                                                            </DataTrigger>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="row" Property="Background"
                                                                        Value="{StaticResource HighlightBrush}"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </DockPanel>
                    </Border>
                </Grid>

                <!-- ── BLUEPRINT PAGE ── -->
                <Grid x:Name="PageBlueprints" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Search bar with autocomplete -->
                    <Grid Margin="20,20,20,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid Grid.Column="0">
                            <TextBox x:Name="BlueprintSearchBox"
                                     Style="{StaticResource NexusTextBox}" Height="44"
                                     Text="{Binding BlueprintSearch, UpdateSourceTrigger=PropertyChanged}"
                                     KeyDown="BlueprintSearch_KeyDown"
                                     TextChanged="BlueprintSearch_TextChanged"
                                     Tag="Search blueprints…"/>
                            <Popup x:Name="BlueprintSuggestPopup"
                                   PlacementTarget="{Binding ElementName=BlueprintSearchBox}"
                                   Placement="Bottom"
                                   Width="{Binding ActualWidth, ElementName=BlueprintSearchBox}"
                                   StaysOpen="False"
                                   AllowsTransparency="True">
                                <Border Background="{StaticResource Bg2NavBrush}"
                                        BorderBrush="{StaticResource NavBorderBrush}"
                                        BorderThickness="1" CornerRadius="0,0,4,4">
                                    <ListBox x:Name="BlueprintSuggestList"
                                             Background="Transparent" BorderThickness="0"
                                             MaxHeight="220"
                                             MouseLeftButtonUp="BlueprintSuggest_Click">
                                        <ListBox.ItemContainerStyle>
                                            <Style TargetType="ListBoxItem">
                                                <Setter Property="Foreground"        Value="{StaticResource FgBrush}"/>
                                                <Setter Property="Background"        Value="Transparent"/>
                                                <Setter Property="Padding"           Value="10,6"/>
                                                <Setter Property="FontFamily"        Value="{StaticResource UiFont}"/>
                                                <Setter Property="FontSize"          Value="13"/>
                                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="{StaticResource HighlightBrush}"/>
                                                    </Trigger>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter Property="Background" Value="{StaticResource AccentDimBrush}"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ListBox.ItemContainerStyle>
                                    </ListBox>
                                </Border>
                            </Popup>
                        </Grid>
                        <Button Grid.Column="1" Content="SEARCH"
                                Style="{StaticResource AccentButton}"
                                Margin="8,0,0,0" Height="44" Padding="20,0" FontSize="12"
                                Command="{Binding SearchBlueprintsCommand}"/>
                    </Grid>

                    <!-- Two-panel: left list / right detail -->
                    <Grid Grid.Row="1" Margin="20,0,20,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="280"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Left: blueprint list -->
                        <Border BorderBrush="{StaticResource NavBorderBrush}" BorderThickness="0,0,1,0">
                            <ListView x:Name="BlueprintList"
                                      Background="Transparent" BorderThickness="0"
                                      ItemsSource="{Binding BlueprintResults}"
                                      SelectionChanged="BlueprintList_SelectionChanged"
                                      ItemContainerStyle="{StaticResource NexusListViewItem}">
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="4,2">
                                            <TextBlock Text="{Binding Name}"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource FgBrush}"/>
                                            <TextBlock Text="{Binding Category}"
                                                       FontSize="11"
                                                       Foreground="{StaticResource FgDimBrush}"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </Border>

                        <!-- Right: ingredient detail panel -->
                        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto"
                                      Margin="16,0,0,0">
                            <StackPanel x:Name="BlueprintDetailPanel"/>
                        </ScrollViewer>
                    </Grid>
                </Grid>

                <!-- ── MINING CODEX PAGE ── -->
                <Grid x:Name="PageReference" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <Grid Grid.Row="0" Margin="20,16,20,10">
                        <TextBlock Text="MINING CODEX" FontSize="11" FontWeight="Bold"
                                   Foreground="{StaticResource FgDimBrush}" VerticalAlignment="Center"/>
                        <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                            <Button x:Name="GroupByBtn" Content="Group: Resource"
                                    Style="{StaticResource NexusButton}"
                                    Height="28" Padding="12,0" FontSize="11" Margin="0,0,6,0"
                                    Click="GroupBy_Click"/>
                            <Button x:Name="ExpandAllBtn" Content="Expand All"
                                    Style="{StaticResource NexusButton}"
                                    Height="28" Padding="12,0" FontSize="11" Margin="0,0,6,0"
                                    Click="ExpandAll_Click"/>
                            <Button Content="Reset Sort" Style="{StaticResource NexusButton}"
                                    Height="28" Padding="12,0" FontSize="11"
                                    Click="ResetSort_Click"/>
                        </StackPanel>
                    </Grid>

                    <!-- Search bar with clear button -->
                    <Grid Grid.Row="1" Margin="20,0,20,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Style="{StaticResource NexusTextBox}" Height="44"
                                 Text="{Binding RefFilter, UpdateSourceTrigger=PropertyChanged}"
                                 KeyDown="RefSearch_KeyDown"
                                 KeyUp="RefSearch_KeyUp"
                                 Tag="Search by resource, location, or blueprint…"/>
                        <Button Grid.Column="1" Content="✕" Style="{StaticResource NexusButton}"
                                Height="44" Width="44" Margin="6,0,0,0"
                                Click="RefClear_Click"/>
                    </Grid>

                    <!-- System filter -->
                    <StackPanel Grid.Row="2" Orientation="Horizontal"
                                Margin="20,0,20,4" VerticalAlignment="Center">
                        <TextBlock Text="System:" FontSize="11"
                                   Foreground="{StaticResource FgDimBrush}"
                                   VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <StackPanel x:Name="SystemFilterPanel" Orientation="Horizontal"/>
                    </StackPanel>

                    <!-- Method filter -->
                    <StackPanel Grid.Row="3" Orientation="Horizontal"
                                Margin="20,0,20,6" VerticalAlignment="Center">
                        <TextBlock Text="Method:" FontSize="11"
                                   Foreground="{StaticResource FgDimBrush}"
                                   VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <StackPanel x:Name="MethodFilterPanel" Orientation="Horizontal"/>
                    </StackPanel>

                    <!-- Legend -->
                    <StackPanel Grid.Row="4" Margin="20,2,20,10">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,3">
                            <TextBlock Text="Rarity:" FontSize="11" FontWeight="Bold"
                                       Foreground="{StaticResource FgDimBrush}"
                                       VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <Ellipse Width="7" Height="7" Fill="#FFD700" VerticalAlignment="Center" Margin="0,0,4,0"/>
                            <TextBlock Text="Legendary" FontSize="11" Foreground="#FFD700" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <Ellipse Width="7" Height="7" Fill="#A855F7" VerticalAlignment="Center" Margin="0,0,4,0"/>
                            <TextBlock Text="Epic" FontSize="11" Foreground="#A855F7" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <Ellipse Width="7" Height="7" Fill="#3B82F6" VerticalAlignment="Center" Margin="0,0,4,0"/>
                            <TextBlock Text="Rare" FontSize="11" Foreground="#3B82F6" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <Ellipse Width="7" Height="7" Fill="#22C55E" VerticalAlignment="Center" Margin="0,0,4,0"/>
                            <TextBlock Text="Uncommon" FontSize="11" Foreground="#22C55E" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <Ellipse Width="7" Height="7" Fill="#9E9E9E" VerticalAlignment="Center" Margin="0,0,4,0"/>
                            <TextBlock Text="Common" FontSize="11" Foreground="#9E9E9E" VerticalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Refinery:" FontSize="11" FontWeight="Bold"
                                       Foreground="{StaticResource FgDimBrush}"
                                       VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <Ellipse Width="7" Height="7" Fill="#22C55E" VerticalAlignment="Center" Margin="0,0,4,0"/>
                            <TextBlock Text="Bonus yield" FontSize="11" Foreground="#22C55E" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <Ellipse Width="7" Height="7" Fill="#8B949E" VerticalAlignment="Center" Margin="0,0,4,0"/>
                            <TextBlock Text="No modifier" FontSize="11" Foreground="#8B949E" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <Ellipse Width="7" Height="7" Fill="#EF4444" VerticalAlignment="Center" Margin="0,0,4,0"/>
                            <TextBlock Text="Reduced yield" FontSize="11" Foreground="#EF4444" VerticalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>

                    <Border Grid.Row="5" Height="1"
                            Background="{StaticResource NavBorderBrush}"
                            Margin="20,0,20,0"/>

                    <!-- Column headers -->
                    <Border Grid.Row="6"
                            Background="{StaticResource Bg2NavBrush}"
                            Margin="8,4,8,0" Padding="0,4">
                        <StackPanel x:Name="RefColumnHeader" Orientation="Horizontal" Margin="8,0,0,0">
                            <TextBlock x:Name="RefCol1Header" Text="Resource"
                                       FontSize="10" FontWeight="Bold"
                                       Foreground="{StaticResource FgDimBrush}"
                                       Width="155"/>
                            <TextBlock Text="Signal"
                                       FontSize="10" FontWeight="Bold"
                                       Foreground="{StaticResource FgDimBrush}"
                                       Width="90"/>
                            <TextBlock Text="Method"
                                       FontSize="10" FontWeight="Bold"
                                       Foreground="{StaticResource FgDimBrush}"/>
                        </StackPanel>
                    </Border>

                    <TreeView x:Name="ReferenceTree" Grid.Row="7"
                              Background="Transparent" BorderThickness="0"
                              Foreground="{StaticResource FgBrush}"
                              Margin="8,4,8,8"/>
                </Grid>

                <!-- ── REFINERY TRACKER PAGE ── -->
                <Grid x:Name="PageWorkOrders" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Toolbar -->
                    <Border Grid.Row="0"
                            Background="{DynamicResource Bg2NavBrush}"
                            BorderBrush="{DynamicResource NavBorderBrush}"
                            BorderThickness="0,0,0,1">
                        <Grid Margin="12,8">
                            <TextBlock Text="REFINERY TRACKER" FontSize="11" FontWeight="Bold"
                                       Foreground="{StaticResource FgDimBrush}"
                                       VerticalAlignment="Center"/>
                            <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                                <Button x:Name="WoNewBtn" Content="+ New"
                                        Style="{StaticResource NexusButton}"
                                        Height="32" Padding="12,0" Margin="0,0,6,0"
                                        Click="NewWorkOrder_Click"/>
                                <Button x:Name="WoSaveBtn" Content="Save"
                                        Style="{StaticResource AccentButton}"
                                        Height="32" Padding="16,0" Margin="0,0,6,0"
                                        IsEnabled="False"
                                        Click="WoSave_Click"/>
                                <Button x:Name="WoDeleteBtn" Content="Delete"
                                        Style="{StaticResource NexusButton}"
                                        Height="32" Padding="12,0"
                                        IsEnabled="False"
                                        Click="WoDelete_Click"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Content -->
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="260"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Grid Grid.Column="0" Background="{DynamicResource Bg2NavBrush}">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel x:Name="WorkOrderListPanel"/>
                            </ScrollViewer>
                        </Grid>

                        <ScrollViewer Grid.Column="1" x:Name="WorkOrderEditor"
                                      VerticalScrollBarVisibility="Auto" Margin="16"/>
                    </Grid>
                </Grid>


            </Grid>
        </Grid>
    </Grid>
</Window>
